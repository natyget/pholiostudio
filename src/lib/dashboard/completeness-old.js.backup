/**
 * Unified Profile Completeness Calculator
 * 
 * Calculates profile completeness across 8 sections:
 * 1. Personal Info
 * 2. Physical Profile
 * 3. Experience/Training
 * 4. Skills/Lifestyle
 * 5. Comfort Boundaries
 * 6. Availability/Locations
 * 7. Social/Portfolio
 * 8. Applications/Matches (always complete)
 * 
 * @param {Object} profile - Profile object from database
 * @param {Array} images - Array of image objects for the profile
 * @returns {Object} Completeness object with sections, basics, imagery, hero, and percentage
 */

function calculateProfileCompleteness(profile, images = []) {
  if (!profile) {
    return {
      basics: false,
      imagery: false,
      hero: false,
      sections: {},
      percentage: 0
    };
  }

  const imagesArray = Array.isArray(images) ? images : [];
  
  // Section 1: Personal Info
  const personalInfoComplete = Boolean(
    profile.first_name &&
    profile.last_name &&
    profile.email &&
    profile.phone &&
    profile.city
  );

  // Section 2: Physical Profile
  const physicalProfileComplete = Boolean(
    profile.height_cm &&
    profile.bust &&
    profile.waist &&
    profile.hips
  );

  // Section 3: Experience/Training
  const experienceTrainingComplete = Boolean(
    profile.experience_level ||
    profile.experience_details ||
    profile.training
  );

  // Section 4: Skills/Lifestyle
  const skillsLifestyleComplete = Boolean(
    profile.specialties ||
    profile.skills
  );

  // Section 5: Comfort Boundaries
  const comfortBoundariesComplete = Boolean(profile.comfort_levels);

  // Section 6: Availability/Locations
  const availabilityLocationsComplete = Boolean(
    (profile.availability_schedule || profile.availability_travel !== undefined) &&
    (profile.city || profile.city_secondary)
  );

  // Section 7: Social/Portfolio
  const hasSocial = Boolean(
    profile.instagram_handle ||
    profile.twitter_handle ||
    profile.tiktok_handle
  );
  const hasPortfolio = Boolean(imagesArray.length > 0 || profile.portfolio_url);
  const socialPortfolioComplete = Boolean(hasSocial && hasPortfolio);

  // Section 8: Applications/Matches (always complete for display purposes)
  const applicationsMatchesComplete = true;

  // Calculate section statuses
  const sections = {
    personalInfo: {
      complete: personalInfoComplete,
      status: personalInfoComplete ? 'complete' : 'incomplete',
      message: personalInfoComplete ? 'Complete' : getPersonalInfoMessage(profile)
    },
    physicalProfile: {
      complete: physicalProfileComplete,
      status: physicalProfileComplete ? 'complete' : 'incomplete',
      message: physicalProfileComplete ? 'Complete' : getPhysicalProfileMessage(profile)
    },
    experienceTraining: {
      complete: experienceTrainingComplete,
      status: experienceTrainingComplete ? 'complete' : 'incomplete',
      message: experienceTrainingComplete ? 'Complete' : 'Add experience'
    },
    skillsLifestyle: {
      complete: skillsLifestyleComplete,
      status: skillsLifestyleComplete ? 'complete' : 'incomplete',
      message: skillsLifestyleComplete ? 'Complete' : 'Add skills'
    },
    comfortBoundaries: {
      complete: comfortBoundariesComplete,
      status: comfortBoundariesComplete ? 'complete' : 'incomplete',
      message: comfortBoundariesComplete ? 'Complete' : 'Set comfort levels'
    },
    availabilityLocations: {
      complete: availabilityLocationsComplete,
      status: availabilityLocationsComplete ? 'complete' : 'incomplete',
      message: availabilityLocationsComplete ? 'Complete' : getAvailabilityLocationsMessage(profile)
    },
    socialPortfolio: {
      complete: socialPortfolioComplete,
      status: socialPortfolioComplete ? 'complete' : 'incomplete',
      message: socialPortfolioComplete ? 'Complete' : getSocialPortfolioMessage(hasSocial, hasPortfolio)
    },
    applicationsMatches: {
      complete: applicationsMatchesComplete,
      status: 'complete',
      message: 'View applications'
    }
  };

  // Count completed sections
  const completedSections = Object.values(sections).filter(s => s.complete).length;
  const percentage = Math.round((completedSections / 8) * 100);

  // Legacy compatibility (simple checks)
  const basics = Boolean(
    profile.first_name &&
    profile.last_name &&
    profile.city &&
    profile.bio_curated
  );
  const imagery = imagesArray.length >= 2;
  const hero = Boolean(profile.hero_image_path || imagesArray.length > 0);

  return {
    basics,
    imagery,
    hero,
    sections,
    percentage
  };
}

/**
 * Helper function to get Personal Info status message
 */
function getPersonalInfoMessage(profile) {
  const required = ['first_name', 'last_name', 'email', 'phone', 'city'];
  const missing = required.filter(field => !profile[field]);
  
  if (missing.length === 0) return 'Complete';
  if (missing.includes('first_name') || missing.includes('last_name')) return 'Missing name';
  if (missing.includes('email')) return 'Missing email';
  if (missing.includes('phone')) return 'Missing phone';
  return `Missing ${missing[0]}`;
}

/**
 * Helper function to get Physical Profile status message
 */
function getPhysicalProfileMessage(profile) {
  const required = ['height_cm', 'bust', 'waist', 'hips'];
  const missing = required.filter(field => !profile[field]);
  
  if (missing.length === 0) return 'Complete';
  if (missing.includes('height_cm')) return 'Missing height';
  if (missing.includes('bust') || missing.includes('waist') || missing.includes('hips')) {
    return 'Missing measurements';
  }
  return 'Incomplete';
}

/**
 * Helper function to get Availability/Locations status message
 */
function getAvailabilityLocationsMessage(profile) {
  const hasAvailability = profile.availability_schedule || profile.availability_travel !== undefined;
  const hasLocation = profile.city || profile.city_secondary;
  
  if (hasAvailability && hasLocation) return 'Complete';
  if (!hasLocation) return 'Add location';
  return 'Set availability';
}

/**
 * Helper function to get Social/Portfolio status message
 */
function getSocialPortfolioMessage(hasSocial, hasPortfolio) {
  if (hasSocial && hasPortfolio) return 'Complete';
  if (!hasPortfolio) return 'Add portfolio images';
  if (!hasSocial) return 'Add social links';
  return 'Incomplete';
}

module.exports = {
  calculateProfileCompleteness
};

