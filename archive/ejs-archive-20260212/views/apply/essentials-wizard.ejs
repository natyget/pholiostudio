<style>
  /* Full-screen wizard - hide header/footer for immersive experience */
  body.essentials-wizard-page > header,
  body.essentials-wizard-page > footer {
    display: none !important;
  }
  
  .essentials-wizard-container {
    min-height: 100vh;
    background: linear-gradient(135deg, #faf9f7 0%, #f5f4f2 100%);
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .wizard-card {
    width: 100%;
    max-width: 800px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }
  
  .wizard-header-section {
    background: linear-gradient(135deg, rgba(201, 165, 90, 0.1) 0%, rgba(201, 165, 90, 0.05) 100%);
    border-bottom: 1px solid rgba(201, 165, 90, 0.2);
    padding: 2rem;
    text-align: center;
  }
  
  .wizard-header-section h1 {
    margin: 0 0 0.5rem 0;
    font-size: 1.75rem;
    font-weight: 600;
    color: #0f172a;
  }
  
  .wizard-header-section p {
    margin: 0;
    color: #64748b;
    font-size: 0.9375rem;
  }
  
  .wizard-progress-bar {
    display: flex;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    background: #f8f9fa;
    border-bottom: 1px solid #e9ecef;
    position: relative;
  }
  
  .progress-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
  }
  
  .progress-item::before {
    content: '';
    position: absolute;
    top: 12px;
    left: 50%;
    right: -50%;
    height: 2px;
    background: #e9ecef;
    z-index: 0;
  }
  
  .progress-item:last-child::before {
    display: none;
  }
  
  .progress-item.active::before,
  .progress-item.completed::before {
    background: rgba(201, 165, 90, 0.5);
  }
  
  .progress-number {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #e9ecef;
    color: #94a3b8;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    position: relative;
    z-index: 1;
  }
  
  .progress-item.active .progress-number {
    background: rgba(201, 165, 90, 1);
    color: white;
  }
  
  .progress-item.completed .progress-number {
    background: rgba(201, 165, 90, 0.8);
    color: white;
  }
  
  .progress-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .progress-item.active .progress-label,
  .progress-item.completed .progress-label {
    color: rgba(201, 165, 90, 0.9);
  }
  
  .wizard-body {
    padding: 2rem;
  }
  
  .wizard-step-panel {
    display: none;
    animation: fadeIn 0.3s ease;
  }
  
  .wizard-step-panel.active {
    display: block;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .wizard-step-panel h2 {
    margin: 0 0 1.5rem 0;
    font-size: 1.5rem;
    font-weight: 600;
    color: #0f172a;
  }
  
  .wizard-form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .wizard-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .wizard-field label {
    font-size: 0.875rem;
    font-weight: 500;
    color: #334155;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .wizard-field input,
  .wizard-field select {
    padding: 0.75rem;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    font-size: 1rem;
    transition: border-color 0.2s;
  }
  
  .wizard-field input:focus,
  .wizard-field select:focus {
    outline: none;
    border-color: rgba(201, 165, 90, 0.5);
    box-shadow: 0 0 0 3px rgba(201, 165, 90, 0.1);
  }
  
  .photo-upload-zone {
    border: 2px dashed #e2e8f0;
    border-radius: 8px;
    padding: 3rem;
    text-align: center;
    background: #f8f9fa;
    cursor: pointer;
    transition: all 0.2s;
    margin-bottom: 1rem;
  }
  
  .photo-upload-zone:hover {
    border-color: rgba(201, 165, 90, 0.5);
    background: rgba(201, 165, 90, 0.05);
  }
  
  .photo-upload-zone.drag-over {
    border-color: rgba(201, 165, 90, 1);
    background: rgba(201, 165, 90, 0.1);
  }
  
  .photo-grid-display {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }
  
  .photo-item {
    position: relative;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid #e2e8f0;
  }
  
  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .photo-item .remove-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(239, 68, 68, 0.9);
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: bold;
  }
  
  .wizard-footer {
    display: flex;
    justify-content: space-between;
    padding: 2rem;
    border-top: 1px solid #e9ecef;
    background: #f8f9fa;
  }
  
  .wizard-btn {
    padding: 0.875rem 1.75rem;
    border-radius: 6px;
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
  }
  
  .wizard-btn-primary {
    background: rgba(201, 165, 90, 1);
    color: #0f172a;
  }
  
  .wizard-btn-primary:hover:not(:disabled) {
    background: rgba(201, 165, 90, 0.9);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(201, 165, 90, 0.3);
  }
  
  .wizard-btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  
  .wizard-btn-secondary {
    background: transparent;
    color: #64748b;
    border: 1px solid #e2e8f0;
  }
  
  .wizard-btn-secondary:hover:not(:disabled) {
    background: #f8f9fa;
    border-color: #cbd5e1;
  }
  
  .wizard-btn-secondary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  
  .wizard-error {
    background: #fee;
    border: 1px solid #fcc;
    color: #c33;
    padding: 0.75rem;
    border-radius: 6px;
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }
  
  .photo-count-text {
    font-size: 0.875rem;
    color: #64748b;
    margin-top: 0.5rem;
    text-align: center;
  }
  
  .photo-count-text.insufficient {
    color: #ef4444;
    font-weight: 500;
  }
</style>

<div class="essentials-wizard-container">
  <div class="wizard-card">
    <div class="wizard-header-section">
      <h1>Complete Your Essentials</h1>
      <p>Fill in the essential information to get started</p>
    </div>
    
    <div class="wizard-progress-bar">
      <div class="progress-item active" data-step="0">
        <div class="progress-number">1</div>
        <div class="progress-label">Basics</div>
      </div>
      <div class="progress-item" data-step="1">
        <div class="progress-number">2</div>
        <div class="progress-label">Measurements</div>
      </div>
      <div class="progress-item" data-step="2">
        <div class="progress-number">3</div>
        <div class="progress-label">Photos</div>
      </div>
    </div>
    
    <form id="essentials-form" class="wizard-body">
      <div id="wizard-error" style="display: none;"></div>
      
      <!-- Step 1: Basics -->
      <div class="wizard-step-panel active" data-step="0">
        <h2>Basic Information</h2>
        <div class="wizard-form-grid">
          <div class="wizard-field">
            <label for="first_name">First Name *</label>
            <input type="text" id="first_name" name="first_name" value="<%= profile?.first_name || '' %>" required>
          </div>
          <div class="wizard-field">
            <label for="last_name">Last Name *</label>
            <input type="text" id="last_name" name="last_name" value="<%= profile?.last_name || '' %>" required>
          </div>
          <div class="wizard-field">
            <label for="city">City *</label>
            <input type="text" id="city" name="city" value="<%= profile?.city || '' %>" required>
          </div>
          <div class="wizard-field">
            <label for="gender">Gender</label>
            <select id="gender" name="gender">
              <option value="">Select...</option>
              <option value="Male" <%= profile?.gender === 'Male' ? 'selected' : '' %>>Male</option>
              <option value="Female" <%= profile?.gender === 'Female' ? 'selected' : '' %>>Female</option>
              <option value="Non-binary" <%= profile?.gender === 'Non-binary' ? 'selected' : '' %>>Non-binary</option>
              <option value="Other" <%= profile?.gender === 'Other' ? 'selected' : '' %>>Other</option>
              <option value="Prefer not to say" <%= profile?.gender === 'Prefer not to say' ? 'selected' : '' %>>Prefer not to say</option>
            </select>
          </div>
          <div class="wizard-field">
            <label for="date_of_birth">Date of Birth</label>
            <input type="date" id="date_of_birth" name="date_of_birth" value="<%= profile?.date_of_birth || '' %>">
          </div>
        </div>
      </div>
      
      <!-- Step 2: Measurements -->
      <div class="wizard-step-panel" data-step="1">
        <h2>Measurements</h2>
        <div class="wizard-form-grid">
          <div class="wizard-field">
            <label for="height_cm">Height (cm) *</label>
            <input type="number" id="height_cm" name="height_cm" min="120" max="220" value="<%= profile?.height_cm || '' %>" required>
          </div>
          <div class="wizard-field">
            <label for="bust">Bust (inches) *</label>
            <input type="number" id="bust" name="bust" step="0.5" min="20" max="60" value="<%= profile?.bust || '' %>" required>
          </div>
          <div class="wizard-field">
            <label for="waist">Waist (inches) *</label>
            <input type="number" id="waist" name="waist" step="0.5" min="20" max="50" value="<%= profile?.waist || '' %>" required>
          </div>
          <div class="wizard-field">
            <label for="hips">Hips (inches) *</label>
            <input type="number" id="hips" name="hips" step="0.5" min="25" max="60" value="<%= profile?.hips || '' %>" required>
          </div>
          <div class="wizard-field">
            <label for="shoe_size">Shoe Size</label>
            <input type="text" id="shoe_size" name="shoe_size" value="<%= profile?.shoe_size || '' %>">
          </div>
        </div>
      </div>
      
      <!-- Step 3: Photos -->
      <div class="wizard-step-panel" data-step="2">
        <h2>Photos</h2>
        <p style="color: #64748b; margin-bottom: 1.5rem;">Upload at least <%= minPhotos %> photos to continue</p>
        
        <div class="photo-upload-zone" id="photo-upload-zone">
          <input type="file" id="photo-input" accept="image/*" multiple style="display: none;">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin: 0 auto 1rem; color: #94a3b8;">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21,15 16,10 5,21"/>
          </svg>
          <p style="margin: 0; font-weight: 500; color: #334155;">Click to upload or drag and drop</p>
          <p style="margin: 0.5rem 0 0 0; font-size: 0.875rem; color: #94a3b8;">JPG, PNG up to 10MB</p>
        </div>
        
        <div class="photo-count-text <%= (photoCount || 0) < minPhotos ? 'insufficient' : '' %>" id="photo-count">
          <%= photoCount || 0 %> / <%= minPhotos %> photos uploaded
        </div>
        
        <div class="photo-grid-display" id="photo-grid">
          <% if (images && images.length > 0) { %>
            <% images.forEach((img, index) => { %>
              <div class="photo-item" data-image-id="<%= img.id %>">
                <img src="<%= img.path %>" alt="Photo <%= index + 1 %>">
                <button type="button" class="remove-btn" data-image-id="<%= img.id %>" onclick="removePhoto('<%= img.id %>')" aria-label="Remove photo">×</button>
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>
    </form>
    
    <div class="wizard-footer">
      <button type="button" class="wizard-btn wizard-btn-secondary" id="prev-btn" disabled>Previous</button>
      <button type="button" class="wizard-btn wizard-btn-primary" id="next-btn">Next</button>
      <button type="submit" class="wizard-btn wizard-btn-primary" id="submit-btn" form="essentials-form" style="display: none;">Submit</button>
    </div>
  </div>
</div>

<script>
  // Wizard state
  let currentStep = 0;
  const totalSteps = 3;
  const minPhotos = <%= minPhotos || 3 %>;
  let photoCount = <%= photoCount || 0 %>;
  
  // Elements
  const form = document.getElementById('essentials-form');
  const steps = document.querySelectorAll('.wizard-step-panel');
  const progressItems = document.querySelectorAll('.progress-item');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const submitBtn = document.getElementById('submit-btn');
  const photoUploadZone = document.getElementById('photo-upload-zone');
  const photoInput = document.getElementById('photo-input');
  const photoGrid = document.getElementById('photo-grid');
  const photoCountEl = document.getElementById('photo-count');
  const errorContainer = document.getElementById('wizard-error');
  
  // Add body class to hide header/footer
  document.body.classList.add('essentials-wizard-page');
  
  // Show step
  function showStep(stepIndex) {
    if (stepIndex < 0 || stepIndex >= totalSteps) return;
    
    steps.forEach((step, index) => {
      step.classList.toggle('active', index === stepIndex);
    });
    
    progressItems.forEach((item, index) => {
      item.classList.remove('active', 'completed');
      if (index < stepIndex) {
        item.classList.add('completed');
      } else if (index === stepIndex) {
        item.classList.add('active');
      }
    });
    
    prevBtn.disabled = stepIndex === 0;
    
    if (stepIndex === totalSteps - 1) {
      nextBtn.style.display = 'none';
      submitBtn.style.display = 'inline-block';
      checkPhotoRequirement();
    } else {
      nextBtn.style.display = 'inline-block';
      submitBtn.style.display = 'none';
    }
    
    currentStep = stepIndex;
  }
  
  // Validate step
  function validateStep(stepIndex) {
    const step = steps[stepIndex];
    if (!step) return true;
    
    const requiredFields = step.querySelectorAll('[required]');
    let isValid = true;
    
    requiredFields.forEach(field => {
      if (!field.checkValidity()) {
        field.reportValidity();
        isValid = false;
      }
    });
    
    if (stepIndex === 2 && photoCount < minPhotos) {
      showError(`Please upload at least ${minPhotos} photos before submitting.`);
      isValid = false;
    }
    
    return isValid;
  }
  
  // Navigation
  nextBtn.addEventListener('click', () => {
    if (validateStep(currentStep)) {
      saveDraft(); // Auto-save before next step
      showStep(currentStep + 1);
    }
  });
  
  prevBtn.addEventListener('click', () => {
    showStep(currentStep - 1);
  });
  
  // Photo upload
  photoUploadZone.addEventListener('click', () => photoInput.click());
  
  ['dragover', 'dragenter'].forEach(eventName => {
    photoUploadZone.addEventListener(eventName, (e) => {
      e.preventDefault();
      photoUploadZone.classList.add('drag-over');
    });
  });
  
  ['dragleave', 'drop'].forEach(eventName => {
    photoUploadZone.addEventListener(eventName, (e) => {
      e.preventDefault();
      photoUploadZone.classList.remove('drag-over');
    });
  });
  
  photoUploadZone.addEventListener('drop', (e) => {
    const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/'));
    uploadPhotos(files);
  });
  
  photoInput.addEventListener('change', (e) => {
    const files = Array.from(e.target.files);
    uploadPhotos(files);
    photoInput.value = ''; // Reset input
  });
  
  async function uploadPhotos(files) {
    for (const file of files) {
      try {
        const formData = new FormData();
        formData.append('file', file);
        
        const response = await fetch('/apply/media/upload', {
          method: 'POST',
          body: formData,
          credentials: 'same-origin'
        });
        
        if (!response.ok) {
          const error = await response.json().catch(() => ({ error: 'Upload failed' }));
          throw new Error(error.error || 'Upload failed');
        }
        
        const result = await response.json();
        addPhotoToGrid(result.path);
        photoCount++;
        updatePhotoCount();
      } catch (error) {
        console.error('Upload error:', error);
        showError(error.message || 'Failed to upload photo');
      }
    }
  }
  
  function addPhotoToGrid(path) {
    const photoItem = document.createElement('div');
    photoItem.className = 'photo-item';
    photoItem.innerHTML = `
      <img src="${path}" alt="Uploaded photo">
      <button type="button" class="remove-btn" onclick="this.parentElement.remove(); photoCount--; updatePhotoCount();">×</button>
    `;
    photoGrid.appendChild(photoItem);
  }
  
  function updatePhotoCount() {
    photoCountEl.textContent = `${photoCount} / ${minPhotos} photos uploaded`;
    photoCountEl.classList.toggle('insufficient', photoCount < minPhotos);
    checkPhotoRequirement();
  }
  
  function checkPhotoRequirement() {
    if (currentStep === totalSteps - 1) {
      submitBtn.disabled = photoCount < minPhotos;
    }
  }
  
  function removePhoto(imageId) {
    // TODO: Add DELETE endpoint if needed
    const photoItem = document.querySelector(`[data-image-id="${imageId}"]`);
    if (photoItem) {
      photoItem.remove();
      photoCount--;
      updatePhotoCount();
    }
  }
  
  // Form submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (!validateStep(currentStep)) return;
    if (photoCount < minPhotos) {
      showError(`Please upload at least ${minPhotos} photos before submitting.`);
      return;
    }
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    
    try {
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
      const response = await fetch('/apply/essentials/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        credentials: 'same-origin',
        redirect: 'manual'
      });
      
      if (response.ok || response.status === 303 || response.status === 302) {
        window.location.href = response.headers.get('location') || '/dashboard/talent?onboarding=1';
      } else {
        const error = await response.json().catch(() => ({ error: 'Submission failed' }));
        showError(error.error || 'Submission failed. Please try again.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit';
      }
    } catch (error) {
      console.error('Submit error:', error);
      showError('An error occurred. Please try again.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit';
    }
  });
  
  // Auto-save (debounced)
  let saveTimeout;
  form.addEventListener('input', () => {
    clearTimeout(saveTimeout);
    saveTimeout = setTimeout(saveDraft, 1000);
  });
  
  async function saveDraft() {
    try {
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
      await fetch('/apply/essentials/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        credentials: 'same-origin'
      });
    } catch (error) {
      console.error('Auto-save error:', error);
    }
  }
  
  function showError(message) {
    errorContainer.innerHTML = `<div class="wizard-error">${message}</div>`;
    errorContainer.style.display = 'block';
    errorContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
  
  // Initialize
  showStep(0);
</script>
