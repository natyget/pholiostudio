function ApplyCinematic() {
  // Flow states: 'auth' | 'arrival' | 'calibration' | 'reveal' | 'complete'
  const [flowState, setFlowState] = useState('auth');
  const [isVisible, setIsVisible] = useState(true);
  const [maverickMessage, setMaverickMessage] = useState("Welcome to Pholio.");
  const [isInitialized, setIsInitialized] = useState(false);
  const [toasts, setToasts] = useState([]);
  const [userName, setUserName] = useState('');
  const [visualEstimates, setVisualEstimates] = useState(null);
  
  const showError = (message) => setToasts(prev => [...prev, { id: Date.now(), message, type: 'error' }]);
  const showSuccess = (message) => setToasts(prev => [...prev, { id: Date.now(), message, type: 'success' }]);
  const removeToast = (id) => setToasts(prev => prev.filter(t => t.id !== id));

  // Initialize
  useEffect(() => {
    // Add class to body to hide header/footer
    document.body.classList.add('apply-cinematic-active');
    
    const init = async () => {
      try {
      const response = await initializeChat();
        
        // Extract user name if available
        if (response.userData?.firstName) {
          setUserName(response.userData.firstName);
        }
        
        // Determine starting flow state based on backend stage
        if (response.stage >= 2) {
          // User is authenticated, skip to arrival
          setFlowState('arrival');
        }
        
        if (response.message) setMaverickMessage(response.message);
        setIsInitialized(true);
    } catch (error) {
        // Init failed - error handling below
        // 401/403 here is expected for logged-out users; stay in auth flow.
        if (error?.status === 401 || error?.status === 403) {
          setFlowState('auth');
          setIsInitialized(true);
          return;
        }
        showError('Failed to initialize. Please refresh.');
      }
    };
    init();
    
    // Cleanup: Remove class when component unmounts
    return () => {
      document.body.classList.remove('apply-cinematic-active');
    };
  }, []);

  // Auth success handler
  const handleAuthSuccess = async () => {
      try {
        const response = await initializeChat();
      if (response.userData?.firstName) setUserName(response.userData.firstName);
        setIsInitialized(true);
        
      // Transition to arrival
      setIsVisible(false);
      setTimeout(() => {
        setFlowState('arrival');
        setIsVisible(true);
      }, 500);
      } catch (error) {
      window.location.reload();
    }
  };

  // Handle arrival completion (after Scout analysis)
  const handleArrivalComplete = (scoutData) => {
    // Store visual estimates for calibration pre-fill
    setVisualEstimates({
      heightFeet: scoutData?.heightEstimateFeet || 5,
      heightInches: scoutData?.heightEstimateInches || 9,
      weight: scoutData?.weightEstimate || 135,
      shoeSize: scoutData?.shoeSizeEstimate || 8,
      bust: scoutData?.bustEstimate || 34,
      waist: scoutData?.waistEstimate || 26,
      hips: scoutData?.hipsEstimate || 36
    });
    
    // Transition to calibration
    setIsVisible(false);
    setTimeout(() => {
      setFlowState('calibration');
      setIsVisible(true);
    }, 500);
  };

  // Handle calibration completion
  const handleCalibrationComplete = (metrics) => {
    // Transition to reveal
    setIsVisible(false);
    setTimeout(() => {
      setFlowState('reveal');
    setIsVisible(true);
    }, 500);
  };

  // Handle reveal completion
  const handleRevealComplete = () => {
    window.location.href = '/dashboard/talent';
  };

  // Handle Maverick message (for auth stage)
  const handleMaverickMessage = (message, action, stage, toolTrigger) => {
    setMaverickMessage(message);
    
    // Check for reveal trigger
    if (action === 'reveal') {
      setFlowState('reveal');
      return;
    }
  };

  // Progress calculation
  const flowStages = ['auth', 'arrival', 'calibration', 'reveal'];
  const visibleStages = ['arrival', 'calibration']; // Stages to show in progress bar
  const currentIndex = flowStages.indexOf(flowState);
  
  // Calculate progress based on visible stages only
  const visibleIndex = visibleStages.indexOf(flowState);
  const progressPercentage = visibleIndex >= 0 
    ? ((visibleIndex + 1) / visibleStages.length) * 100 
    : 0;
  
  const stageNames = {
    auth: 'Authentication',
    arrival: 'Visual Capture',
    calibration: 'Calibration',
    reveal: 'Your Reveal'
  };

  return (
    <div className="apply-cinematic">
      {/* Progress Bar with Segmented Labels - Show only during arrival and calibration */}
      {flowState === 'arrival' || flowState === 'calibration' ? (
        <div className="apply-progress-header">
          <div className="apply-progress-segments">
            {visibleStages.map((stage, index) => {
              const isActive = flowState === stage || (flowState === 'calibration' && stage === 'arrival');
              const isCurrent = flowState === stage;
              return (
                <div 
                  key={stage} 
                  className={`progress-segment ${isActive ? 'active' : ''} ${isCurrent ? 'current' : ''}`}
                >
                  <div className="progress-segment-label">{stageNames[stage] || stage}</div>
                  <div className="progress-segment-indicator"></div>
                </div>
              );
            })}
          </div>
          <div className="apply-progress-bar">
            <div className="apply-progress-bar-fill" style={{ width: `${progressPercentage}%` }}></div>
          </div>
        </div>
      ) : null}

            {/* Toast Notifications */}
      <div className="toast-container">
              {toasts.map(toast => (
          <Toast key={toast.id} message={toast.message} type={toast.type} onClose={() => removeToast(toast.id)} />
              ))}
            </div>

      {/* Flow Stages */}
      {flowState === 'auth' && (
        <div className={`onboarding-container ${isVisible ? '' : 'onboarding-exit'}`}>
          <div className="chat-container">
            <MaverickMessage text={maverickMessage} />
            <SocialAuthStage 
              onContinue={() => {}} 
              isVisible={isVisible} 
              onMaverickMessage={handleMaverickMessage}
              onAuthSuccess={handleAuthSuccess}
              showError={showError}
            />
          </div>
        </div>
      )}

      {flowState === 'arrival' && (
        <ArrivalStage 
          onComplete={handleArrivalComplete}
          isVisible={isVisible}
          userName={userName}
          showError={showError}
        />
      )}

      {flowState === 'calibration' && (
        <CalibrationStage 
          onComplete={handleCalibrationComplete}
          isVisible={isVisible}
          visualEstimates={visualEstimates}
          showError={showError}
        />
      )}

      {flowState === 'reveal' && (
        <RevealOverlay 
          onComplete={handleRevealComplete}
          showError={showError}
        />
      )}
    </div>
  );
}

// ============================================================================
// RENDER
// ============================================================================

const container = document.getElementById('apply-cinematic-root');
const root = ReactDOM.createRoot(container);
root.render(<ApplyCinematic />);

// Mouse tracking for background gradient
setTimeout(() => {
  const applyCinematic = document.querySelector('.apply-cinematic');
  if (applyCinematic) {
    applyCinematic.addEventListener('mousemove', (e) => {
      const rect = applyCinematic.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      applyCinematic.style.setProperty('--mouse-x', `${x}%`);
      applyCinematic.style.setProperty('--mouse-y', `${y}%`);
    });
  }
}, 100);
</script>
