function RevealOverlay({ onComplete, showError }) {
  const [revealData, setRevealData] = useState(null);
  const [loading, setLoading] = useState(true);
  const [currentCard, setCurrentCard] = useState(0); // 0 = Score, 1 = Radar, 2 = Comp
  const [maverickText, setMaverickText] = useState('Everything aligned.');
  const [maverickSubtext, setMaverickSubtext] = useState('Let me reveal your Pholio potential.');
  
  const overlayRef = useRef(null);
  const scoreCardRef = useRef(null);
  const radarCardRef = useRef(null);
  const compCardRef = useRef(null);
  const gaugeChartRef = useRef(null);
  const radarChartRef = useRef(null);
  const gaugeCanvasRef = useRef(null);
  const radarCanvasRef = useRef(null);

  // Fetch reveal data
  useEffect(() => {
    const fetchData = async () => {
