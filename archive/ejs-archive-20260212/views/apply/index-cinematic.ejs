function SocialAuthStage({ onContinue, isVisible, onMaverickMessage, onAuthSuccess, showError }) {
  const handleGoogle = async () => {
    try {
      let attempts = 0;
      while (!window.FirebaseAuth || typeof window.FirebaseAuth.signInWithGoogle !== 'function') {
        if (attempts >= 30) {
          alert('Authentication system not ready. Please refresh.');
          return;
        }
        await new Promise(resolve => setTimeout(resolve, 100));
        attempts++;
      }

      const userCredential = await window.FirebaseAuth.signInWithGoogle();
      if (!userCredential) return; // Redirect flow

      const user = userCredential.user;
      const idToken = await user.getIdToken();

      const authResponse = await fetch('/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        credentials: 'include',
        redirect: 'manual',
        body: JSON.stringify({ firebase_token: idToken })
      });

      if (onAuthSuccess) onAuthSuccess();
      else window.location.reload();
    } catch (error) {
      if (error.code !== 'auth/popup-closed-by-user') {
        if (showError) showError(error.message || 'Google Sign-In failed.');
      }
    }
  };

  const handleManual = async () => {
    const response = await sendChatMessage('I want to continue manually');
    if (response.message && onMaverickMessage) {
      onMaverickMessage(response.message, response.action, response.stage, response.tool_trigger);
    }
    if (response.action !== 'continue') await onContinue();
  };

  return (
    <div className={`stage-container social-auth-stage glass-entry ${isVisible ? 'visible' : ''}`}>
      <button className="social-auth-button" onClick={handleGoogle}>
        <svg width="20" height="20" viewBox="0 0 18 18" fill="none">
          <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/>
          <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332C2.438 15.983 5.482 18 9 18z"/>
          <path fill="#FBBC05" d="M3.964 10.707c-.18-.54-.282-1.117-.282-1.707s.102-1.167.282-1.707V4.961H.957C.348 6.175 0 7.55 0 9s.348 2.825.957 4.039l3.007-2.332z"/>
          <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.482 0 2.438 2.017.957 4.961L3.964 7.293C4.672 5.163 6.656 3.58 9 3.58z"/>
        </svg>
        Sign up with Google
        </button>
      <a className="continue-manually" onClick={handleManual} style={{ cursor: 'pointer' }}>
        Or continue manually
      </a>
    </div>
  );
}

