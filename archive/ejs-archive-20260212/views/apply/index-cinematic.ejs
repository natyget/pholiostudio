<div id="apply-cinematic-root"></div>

<link rel="stylesheet" href="/styles/apply-cinematic.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">

<!-- React and ReactDOM from CDN -->
<script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>
<script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
<!-- Babel Standalone for JSX transform -->
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<!-- Chart.js for gauge and radar chart -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<!-- GSAP for animations -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<!-- Confetti for success animation -->
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js"></script>

<script type="text/babel">
const { useState, useEffect, useRef, useCallback } = React;

// ============================================================================
// API FUNCTIONS
// ============================================================================

async function fetchJson(url, options = {}) {
  const headers = {
    Accept: 'application/json',
    ...(options.headers || {})
  };

  const res = await fetch(url, {
    credentials: 'include',
    ...options,
    headers
  });

  const contentType = res.headers.get('content-type') || '';
  if (!contentType.includes('application/json')) {
    const text = await res.text().catch(() => '');
    const err = new Error(`Non-JSON response (${res.status}).`);
    err.status = res.status;
    err.contentType = contentType;
    err.preview = text.substring(0, 500);
    throw err;
  }

  const data = await res.json().catch(() => null);
  if (!res.ok) {
    const err = new Error(data?.error || data?.message || `HTTP ${res.status}`);
    err.status = res.status;
    err.data = data;
    throw err;
  }

  return data;
}

async function initializeChat() {
  return fetchJson('/api/chat/initialize', { method: 'POST' });
}

async function sendChatMessage(message) {
  return fetchJson('/api/chat', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ message })
  });
}

async function uploadImageForScout(file) {
  const formData = new FormData();
  formData.append('image', file);
  return fetchJson('/api/upload', {
    method: 'POST',
    body: formData
  });
}

async function getRevealData() {
  const data = await fetchJson('/api/chat/reveal', { method: 'POST' });
  if (!data?.success) throw new Error(data?.error || 'Failed to fetch reveal data');
  return data;
}

// ============================================================================
// UTILITY: Gold Confetti Burst
// ============================================================================

function triggerGoldConfetti(options = {}) {
  if (!window.confetti) return;
  
  const defaults = {
    particleCount: 100,
    spread: 70,
    origin: { y: 0.6 },
    colors: ['#C9A55A', '#FFD700', '#DAA520', '#F0E68C', '#B8860B'],
    shapes: ['circle', 'square'],
    scalar: 1.2
  };
  
  window.confetti({ ...defaults, ...options });
}

function triggerConfettiBurst(x = 0.5, y = 0.5) {
  if (!window.confetti) return;
  
  // Burst from specific point
  window.confetti({
    particleCount: 50,
    spread: 60,
    origin: { x, y },
    colors: ['#C9A55A', '#FFD700', '#DAA520'],
    startVelocity: 30,
    gravity: 0.8,
    scalar: 0.8
  });
}

// ============================================================================
// TOAST NOTIFICATION COMPONENT
// ============================================================================

function Toast({ message, type = 'error', onClose }) {
  const [visible, setVisible] = useState(true);

  useEffect(() => {
    const timer = setTimeout(() => {
      setVisible(false);
      setTimeout(() => onClose(), 300);
    }, 5000);
    return () => clearTimeout(timer);
  }, [onClose]);

  if (!visible) return null;

  return (
    <div className={`toast toast-${type}`} role="alert">
      <div className="toast-content">
        <span className="toast-icon">{type === 'error' ? '⚠️' : '✓'}</span>
        <span className="toast-message">{message}</span>
        <button className="toast-close" onClick={() => { setVisible(false); setTimeout(() => onClose(), 300); }}>×</button>
      </div>
    </div>
  );
}

// ============================================================================
// MAVERICK MESSAGE COMPONENT - Full-Screen Cinematic
// ============================================================================

function MaverickFullScreen({ text, subtext, isVisible, variant = 'default' }) {
  const containerRef = useRef(null);
  
  useEffect(() => {
    if (isVisible && containerRef.current && window.gsap) {
      const gsap = window.gsap;
      
      // Staggered text reveal
      gsap.fromTo(containerRef.current.querySelector('.maverick-fullscreen-text'),
        { opacity: 0, y: 30, filter: 'blur(10px)' },
        { opacity: 1, y: 0, filter: 'blur(0px)', duration: 1, ease: 'power3.out' }
      );
      
      if (subtext) {
        gsap.fromTo(containerRef.current.querySelector('.maverick-fullscreen-subtext'),
          { opacity: 0, y: 20 },
          { opacity: 1, y: 0, duration: 0.8, delay: 0.5, ease: 'power2.out' }
        );
      }
    }
  }, [isVisible, text, subtext]);
  
  return (
    <div ref={containerRef} className={`maverick-fullscreen ${variant} ${isVisible ? 'visible' : ''}`}>
      <div className="maverick-fullscreen-content">
        <div className="maverick-fullscreen-text">{text}</div>
        {subtext && <div className="maverick-fullscreen-subtext">{subtext}</div>}
      </div>
    </div>
  );
}

// ============================================================================
// MAVERICK MESSAGE COMPONENT - Split-Tone Typography (Compact)
// ============================================================================

function MaverickMessage({ text }) {
  const [visible, setVisible] = useState(false);
  const [exiting, setExiting] = useState(false);
  const prevTextRef = useRef(null);
  
  const separator = text?.includes('|') ? '|' : (text?.includes('\n\n') ? '\n\n' : null);
  const parts = separator ? text.split(separator) : [text];
  const insight = parts[0]?.trim() || text;
  const instruction = parts[1]?.trim() || null;
  const hasInstruction = !!instruction;
  
  useEffect(() => {
    if (prevTextRef.current !== null && prevTextRef.current !== text) {
      setExiting(true);
      setVisible(false);
      const exitTimer = setTimeout(() => {
        setExiting(false);
        prevTextRef.current = text;
        setTimeout(() => setVisible(true), 50);
      }, 300);
      return () => clearTimeout(exitTimer);
    } else {
      prevTextRef.current = text;
      setTimeout(() => setVisible(true), 50);
    }
  }, [text]);
  
  return (
    <div key={text} className={`maverick-message ${visible ? 'visible' : ''} ${exiting ? 'exiting' : ''} ${hasInstruction ? 'has-instruction' : ''}`}>
      <div className="maverick-insight">{insight}</div>
      {instruction && <div className="maverick-instruction">{instruction}</div>}
    </div>
  );
}

// ============================================================================
// STAGE 1: ARRIVAL & CAPTURE - Full-Screen Welcome + Image Upload
// ============================================================================

function ArrivalStage({ onComplete, isVisible, userName, showError }) {
  const [phase, setPhase] = useState('welcome'); // 'welcome' | 'upload' | 'scanning' | 'analyzed'
  const [imageFile, setImageFile] = useState(null);
  const [imagePreview, setImagePreview] = useState(null);
  const [isDragOver, setIsDragOver] = useState(false);
  const [scoutAnalysis, setScoutAnalysis] = useState(null);
  const [maverickText, setMaverickText] = useState('');
  const [maverickSubtext, setMaverickSubtext] = useState('');
  const [isUploading, setIsUploading] = useState(false);
  const containerRef = useRef(null);
  const dropZoneRef = useRef(null);
  
  // Initial welcome message
  useEffect(() => {
    if (isVisible && phase === 'welcome') {
      const name = userName || 'there';
      setMaverickText(`Welcome, ${name}.`);
      setMaverickSubtext("I've analyzed your digital footprint — let's get an editorial-grade shot.");
      
      // Transition to upload phase after welcome
      const timer = setTimeout(() => {
        setPhase('upload');
      }, 3000);
      
      return () => clearTimeout(timer);
    }
  }, [isVisible, phase, userName]);
  
  // Animate drop zone entrance
  useEffect(() => {
    if (phase === 'upload' && dropZoneRef.current && window.gsap) {
      const gsap = window.gsap;
      gsap.fromTo(dropZoneRef.current,
        { opacity: 0, scale: 0.9, y: 50 },
        { opacity: 1, scale: 1, y: 0, duration: 0.8, ease: 'power3.out' }
      );
    }
  }, [phase]);

  const handleFileSelect = async (file) => {
    // Validate file
    if (!file) {
      if (showError) showError('No file selected.');
      return;
    }
    
    // Validate file type
    if (!file.type.startsWith('image/')) {
      if (showError) showError('Please select an image file.');
      return;
    }
    
    // Validate file size (max 10MB)
    const maxSize = 10 * 1024 * 1024; // 10MB
    if (file.size > maxSize) {
      if (showError) showError('Image file is too large. Please select an image under 10MB.');
      return;
    }
    
    try {
      setImageFile(file);
      const reader = new FileReader();
      
      // Handle FileReader errors
      reader.onerror = () => {
        if (showError) showError('Failed to read image file.');
        setPhase('upload');
      };
      
      reader.onloadend = () => {
        if (reader.result) {
          setImagePreview(reader.result);
          setPhase('scanning');
          setMaverickText('Analyzing...');
          setMaverickSubtext('Scout is examining your visual presence.');
        } else {
          if (showError) showError('Failed to load image preview.');
          setPhase('upload');
        }
      };
      
      reader.readAsDataURL(file);
      
      // Upload to Scout
      setIsUploading(true);
      const result = await uploadImageForScout(file);
      setIsUploading(false);
      
      if (!result || !result.success) {
        throw new Error(result?.error || 'Upload failed');
      }
      
      if (result.visualIntel) {
        setScoutAnalysis(result.visualIntel);
        setPhase('analyzed');
        
        // Maverick acknowledges specifics
        // Extract facial symmetry score from nested structure
        const faceScore = result.visualIntel?.analysis?.facialSymmetry?.score || 
                         result.visualIntel?.facialSymmetry?.score || 
                         8.5;
        
        // Extract market fit - handle both object and string formats
        let marketFitText = 'Editorial';
        const marketFitObj = result.visualIntel?.analysis?.marketFit || result.visualIntel?.marketFit;
        
        if (typeof marketFitObj === 'string') {
          marketFitText = marketFitObj;
        } else if (marketFitObj && typeof marketFitObj === 'object') {
          if (marketFitObj.overall && typeof marketFitObj.overall === 'string') {
            const overall = marketFitObj.overall.toLowerCase();
            if (overall.includes('editorial')) marketFitText = 'Editorial';
            else if (overall.includes('commercial')) marketFitText = 'Commercial';
            else if (overall.includes('runway')) marketFitText = 'Runway';
            else {
              if (marketFitObj.editorial === 'high') marketFitText = 'Editorial';
              else if (marketFitObj.commercial === 'high') marketFitText = 'Commercial';
              else if (marketFitObj.runway === 'high') marketFitText = 'Runway';
              else marketFitText = 'Editorial';
            }
          } else {
            if (marketFitObj.editorial === 'high') marketFitText = 'Editorial';
            else if (marketFitObj.commercial === 'high') marketFitText = 'Commercial';
            else if (marketFitObj.runway === 'high') marketFitText = 'Runway';
            else marketFitText = 'Editorial';
          }
        }
        
        setMaverickText(`Facial symmetry elite (${faceScore}/10).`);
        setMaverickSubtext(`Strong ${marketFitText.toLowerCase()} fit detected.`);
        
        // Trigger confetti on successful analysis
        setTimeout(() => triggerGoldConfetti({ particleCount: 50, spread: 50 }), 500);
        
        // Auto-advance after showing results
        const advanceTimer = setTimeout(() => {
          onComplete(result.visualIntel);
        }, 2500);
        
        // Store timer for cleanup
        return () => clearTimeout(advanceTimer);
      } else {
        throw new Error('No visual intelligence data received');
      }
    } catch (error) {
      setIsUploading(false);
      setPhase('upload');
      setImagePreview(null);
      setImageFile(null);
      if (showError) {
        const errorMessage = error?.message || error?.error || 'Failed to analyze image. Please try again.';
        showError(errorMessage);
      }
    }
  };

  const handleDrop = (e) => {
    e.preventDefault();
    setIsDragOver(false);
    const file = e.dataTransfer.files[0];
    if (file) handleFileSelect(file);
  };

  const handleDragOver = (e) => { e.preventDefault(); setIsDragOver(true); };
  const handleDragLeave = () => setIsDragOver(false);
  const handleInputChange = (e) => { if (e.target.files[0]) handleFileSelect(e.target.files[0]); };

  return (
    <div ref={containerRef} className={`arrival-stage ${isVisible ? 'visible' : ''}`}>
      {/* Full-Screen Maverick Message */}
      <MaverickFullScreen 
        text={maverickText} 
        subtext={maverickSubtext} 
        isVisible={phase === 'welcome' || phase === 'scanning' || phase === 'analyzed'} 
        variant={phase === 'analyzed' ? 'success' : 'default'}
      />
      
      {/* Image Drop Zone */}
      {(phase === 'upload' || phase === 'scanning' || phase === 'analyzed') && (
        <div
          ref={dropZoneRef}
          className={`arrival-drop-zone ${imagePreview ? 'has-image' : ''} ${isDragOver ? 'drag-over' : ''} ${phase}`}
        onDrop={handleDrop}
        onDragOver={handleDragOver}
        onDragLeave={handleDragLeave}
          onClick={() => phase === 'upload' && document.getElementById('arrival-image-input').click()}
      >
          {/* Holographic Scan Overlay */}
          {phase === 'scanning' && <div className="holographic-scan-advanced" />}
        
          {/* Image Preview */}
        {imagePreview ? (
            <div className="arrival-image-container">
              <img src={imagePreview} alt="Preview" className="arrival-image-preview" />
              {phase === 'analyzed' && (
                <div className="arrival-analysis-overlay">
                  <div className="analysis-badge">✓ Visual Intel Captured</div>
              </div>
            )}
              </div>
          ) : (
            <div className="arrival-drop-content">
              <div className="arrival-drop-icon">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21,15 16,10 5,21"/>
                </svg>
              </div>
              <div className="arrival-drop-text">Drop your best shot</div>
              <div className="arrival-drop-hint">or click to browse</div>
            </div>
        )}
        
        <input
          id="arrival-image-input"
          type="file"
          accept="image/*"
          style={{ display: 'none' }}
          onChange={handleInputChange}
          aria-label="Upload image file"
        />
      </div>
      )}
    </div>
  );
}

// ============================================================================
// STAGE 2: CALIBRATION - Kinetic Sliders with Pre-filled Values
// ============================================================================

function CalibrationStage({ onComplete, isVisible, visualEstimates, showError }) {
  const [phase, setPhase] = useState('transition'); // 'transition' | 'height' | 'weight' | 'shoe' | 'proportions' | 'complete'
  const [maverickText, setMaverickText] = useState('');
  const [maverickSubtext, setMaverickSubtext] = useState('');
  const [confirmedMetrics, setConfirmedMetrics] = useState({});
  
  // Slider states - pre-filled from Scout estimates
  const [heightFeet, setHeightFeet] = useState(visualEstimates?.heightFeet || 5);
  const [heightInches, setHeightInches] = useState(visualEstimates?.heightInches || 10);
  const [weight, setWeight] = useState(visualEstimates?.weight || 140);
  const [shoeSize, setShoeSize] = useState(visualEstimates?.shoeSize || 9);
  const [bust, setBust] = useState(visualEstimates?.bust || 34);
  const [waist, setWaist] = useState(visualEstimates?.waist || 26);
  const [hips, setHips] = useState(visualEstimates?.hips || 36);
  
  const [shimmeringMetric, setShimmeringMetric] = useState(null);
  const [isSubmitting, setIsSubmitting] = useState(false);
  const containerRef = useRef(null);
  const sliderRef = useRef(null);
  
  // Initial transition
  useEffect(() => {
    if (isVisible && phase === 'transition') {
      setMaverickText('Proportions calibrated.');
      setMaverickSubtext('Surgical precision.');
      
      // Gold pulse effect on screen
      let pulseTimer;
      if (containerRef.current) {
        containerRef.current.classList.add('gold-pulse');
        pulseTimer = setTimeout(() => containerRef.current?.classList.remove('gold-pulse'), 1000);
      }
      
      // Move to first slider
      const timer = setTimeout(() => setPhase('height'), 2000);
      return () => {
        clearTimeout(timer);
        if (pulseTimer) clearTimeout(pulseTimer);
      };
    }
  }, [isVisible, phase]);
  
  // Animate slider entrance
  useEffect(() => {
    if (sliderRef.current && window.gsap && phase !== 'transition' && phase !== 'complete') {
      const gsap = window.gsap;
      const animation = gsap.fromTo(sliderRef.current,
        { opacity: 0, y: 30, scale: 0.95 },
        { opacity: 1, y: 0, scale: 1, duration: 0.6, ease: 'back.out(1.7)' }
      );
      
      return () => {
        if (animation) animation.kill();
      };
    }
  }, [phase]);

  const shimmerTimersRef = useRef(new Set());
  const debounceTimersRef = useRef({});
  
  const triggerShimmer = useCallback((metric) => {
    // Clear any existing timer for this metric
    shimmerTimersRef.current.forEach(timer => clearTimeout(timer));
    shimmerTimersRef.current.clear();
    
    setShimmeringMetric(metric);
    const timer = setTimeout(() => {
      setShimmeringMetric(null);
      shimmerTimersRef.current.delete(timer);
    }, 600);
    shimmerTimersRef.current.add(timer);
  }, []);
  
  // Cleanup shimmer and debounce timers on unmount
  useEffect(() => {
    return () => {
      shimmerTimersRef.current.forEach(timer => clearTimeout(timer));
      shimmerTimersRef.current.clear();
      Object.values(debounceTimersRef.current).forEach(timer => clearTimeout(timer));
      debounceTimersRef.current = {};
    };
  }, []);
  
  const handleConfirm = useCallback(async (metric, value, unit = '') => {
    setIsSubmitting(true);
    triggerConfettiBurst(0.5, 0.5);
    
    try {
      const message = `User confirmed ${metric}: ${value}${unit}`;
      await sendChatMessage(message);
      
      // Use functional update to ensure we get the latest state
      setConfirmedMetrics(prev => {
        const updated = { ...prev, [metric.toLowerCase()]: value };
        
        // Progress to next slider
        const phases = ['height', 'weight', 'shoe', 'proportions', 'complete'];
        const currentIndex = phases.indexOf(phase);
        
        if (currentIndex < phases.length - 1) {
          const nextPhase = phases[currentIndex + 1];
          
          // Animate out current slider
          if (sliderRef.current && window.gsap) {
            const gsap = window.gsap;
            gsap.to(sliderRef.current, {
              opacity: 0,
              y: -30,
              duration: 0.4,
              ease: 'power2.in',
              onComplete: () => setPhase(nextPhase)
            });
          } else {
            setPhase(nextPhase);
          }
          
          // If next phase is complete, call onComplete with updated metrics
          if (nextPhase === 'complete') {
            setTimeout(() => {
              triggerGoldConfetti({ particleCount: 100, spread: 80 });
              onComplete(updated);
            }, 500);
          }
        }
        
        return updated;
      });
    } catch (error) {
      if (showError) showError(error.message || 'Failed to save. Please try again.');
    } finally {
      setIsSubmitting(false);
    }
  }, [phase, showError, onComplete]);

  // Render current slider based on phase
  const renderSlider = () => {
    switch (phase) {
      case 'height':
        const isProjectedHeight = visualEstimates?.heightFeet === heightFeet && visualEstimates?.heightInches === heightInches;
        return (
          <div ref={sliderRef} className="calibration-slider-card">
            <div className="calibration-slider-label">HEIGHT</div>
            <div className="calibration-height-display">
              <div className="height-main-controls">
                <button 
                  className="calibration-btn" 
                  onClick={() => { 
                    setHeightFeet(f => Math.max(3, Math.min(8, f - 1))); 
                    triggerShimmer('height'); 
                  }}
                  aria-label="Decrease feet"
                >−</button>
                <div className={`calibration-value ${shimmeringMetric === 'height' ? 'shimmering' : ''}`}>
                  {isProjectedHeight && <span className="projected-label">PROJECTED</span>}
                  <div className="height-display-row">
                    <span className="height-feet">{heightFeet}'</span>
                    <span className="height-inches">{heightInches}"</span>
                  </div>
                </div>
                <button 
                  className="calibration-btn" 
                  onClick={() => { 
                    setHeightFeet(f => Math.max(3, Math.min(8, f + 1))); 
                    triggerShimmer('height'); 
                  }}
                  aria-label="Increase feet"
                >+</button>
              </div>
              <div className="height-inches-controls">
                <button className="calibration-btn small" onClick={() => { setHeightInches(i => i === 0 ? 11 : i - 1); triggerShimmer('height'); }}>−</button>
                <div className="height-inches-label">inches</div>
                <button className="calibration-btn small" onClick={() => { setHeightInches(i => i === 11 ? 0 : i + 1); triggerShimmer('height'); }}>+</button>
              </div>
            </div>
            <button 
              className="calibration-confirm-btn" 
              onClick={() => {
                const heightCm = Math.round((heightFeet * 30.48) + (heightInches * 2.54));
                handleConfirm('Height', `${heightFeet}'${heightInches}" (${heightCm} cm)`);
              }}
              disabled={isSubmitting}
            >
              {isSubmitting ? 'Confirming...' : 'Confirm'}
            </button>
          </div>
        );
        
      case 'weight':
        const isProjectedWeight = visualEstimates?.weight === weight;
        return (
          <div ref={sliderRef} className="calibration-slider-card">
            <div className="calibration-slider-label">WEIGHT</div>
            <div className="calibration-metric-display">
              <button 
                className="calibration-btn" 
                onClick={() => { 
                  setWeight(w => Math.max(80, Math.min(300, w - 5))); 
                  triggerShimmer('weight'); 
                }}
                aria-label="Decrease weight"
              >−</button>
              <div className={`calibration-value ${shimmeringMetric === 'weight' ? 'shimmering' : ''}`}>
                {isProjectedWeight && <span className="projected-label">PROJECTED</span>}
                {weight}<span className="unit">lbs</span>
              </div>
              <button 
                className="calibration-btn" 
                onClick={() => { 
                  setWeight(w => Math.max(80, Math.min(300, w + 5))); 
                  triggerShimmer('weight'); 
                }}
                aria-label="Increase weight"
              >+</button>
            </div>
            <button 
              className="calibration-confirm-btn" 
              onClick={() => {
                if (weight < 80 || weight > 300) {
                  if (showError) showError('Weight must be between 80 and 300 lbs.');
                  return;
                }
                handleConfirm('Weight', weight, ' lbs');
              }}
              disabled={isSubmitting}
              aria-label="Confirm weight"
            >
              {isSubmitting ? 'Confirming...' : 'Confirm'}
            </button>
          </div>
        );
        
      case 'shoe':
        const isProjectedShoe = visualEstimates?.shoeSize === shoeSize;
          return (
          <div ref={sliderRef} className="calibration-slider-card">
            <div className="calibration-slider-label">SHOE SIZE</div>
            <div className="calibration-metric-display">
              <button className="calibration-btn" onClick={() => { setShoeSize(s => Math.max(4, s - 0.5)); triggerShimmer('shoe'); }}>−</button>
              <div className={`calibration-value ${shimmeringMetric === 'shoe' ? 'shimmering' : ''}`}>
                {isProjectedShoe && <span className="projected-label">PROJECTED</span>}
                {shoeSize}<span className="unit">US</span>
              </div>
              <button className="calibration-btn" onClick={() => { setShoeSize(s => Math.min(15, s + 0.5)); triggerShimmer('shoe'); }}>+</button>
            </div>
            <button 
              className="calibration-confirm-btn" 
              onClick={() => handleConfirm('Shoe Size', shoeSize)}
                disabled={isSubmitting}
            >
