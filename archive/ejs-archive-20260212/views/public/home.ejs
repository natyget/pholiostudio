<!-- Dashboard Showcase Section -->
<section class="dashboard-showcase" id="dashboard-showcase">
  <div class="dashboard-showcase__container">
    <div class="dashboard-showcase__header">
      <h2 class="dashboard-showcase__title">Your Dashboard, Your Way</h2>
      <p class="dashboard-showcase__subtitle">Experience the power of Pholio from both perspectives</p>
    </div>

    <div class="dashboard-showcase__content">
      <!-- Talent Dashboard Preview -->
      <div class="dashboard-showcase__panel dashboard-showcase__panel--talent">
        <div class="dashboard-showcase__panel-header">
          <div class="dashboard-showcase__panel-badge dashboard-showcase__panel-badge--talent">For Talent</div>
          <h3 class="dashboard-showcase__panel-title">Manage Your Portfolio</h3>
        </div>
        
        <div class="dashboard-showcase__mockup">
          <!-- Talent Hero Section -->
          <div class="dashboard-showcase__talent-hero">
            <div class="dashboard-showcase__talent-image">
              <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?auto=format&fit=crop&w=400&q=80" alt="Talent profile" loading="lazy">
            </div>
            <div class="dashboard-showcase__talent-info">
              <div class="dashboard-showcase__talent-name-wrapper">
                <h4 class="dashboard-showcase__talent-name">Elara Keats</h4>
                <span class="dashboard-showcase__badge dashboard-showcase__badge--pro">STUDIO+</span>
              </div>
              <p class="dashboard-showcase__talent-location">Los Angeles, CA</p>
              <div class="dashboard-showcase__talent-stats">
                <div class="dashboard-showcase__stat">
                  <span class="dashboard-showcase__stat-label">Height</span>
                  <span class="dashboard-showcase__stat-value">180 cm</span>
                </div>
                <div class="dashboard-showcase__stat">
                  <span class="dashboard-showcase__stat-label">Images</span>
                  <span class="dashboard-showcase__stat-value">8</span>
                </div>
                <div class="dashboard-showcase__stat">
                  <span class="dashboard-showcase__stat-label">Profile</span>
                  <span class="dashboard-showcase__stat-value dashboard-showcase__stat-value--complete">95%</span>
                </div>
              </div>
              <div class="dashboard-showcase__talent-actions">
                <button class="dashboard-showcase__button dashboard-showcase__button--primary">Download Comp Card</button>
                <button class="dashboard-showcase__button dashboard-showcase__button--secondary">View Portfolio</button>
              </div>
            </div>
          </div>

          <!-- Profile Progress with Animation -->
          <div class="dashboard-showcase__progress" id="talent-profile-progress">
