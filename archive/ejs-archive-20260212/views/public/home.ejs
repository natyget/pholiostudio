<script>
// Billing toggle functionality
document.addEventListener('DOMContentLoaded', function() {
  const toggleButtons = document.querySelectorAll('.billing-toggle');
  const priceDisplays = document.querySelectorAll('.price-display');
  
  toggleButtons.forEach(button => {
    button.addEventListener('click', function() {
      const period = this.getAttribute('data-period');
      const isMonthly = period === 'monthly';
      
      // Update button states
      toggleButtons.forEach(btn => {
        if (btn.getAttribute('data-period') === period) {
          btn.style.background = '#C9A55A';
          btn.style.color = 'white';
        } else {
          btn.style.background = 'transparent';
          btn.style.color = '#64748b';
        }
      });
      
      // Update price displays
      priceDisplays.forEach(display => {
        const displayIsMonthly = display.getAttribute('data-monthly') === 'true';
        display.style.display = (displayIsMonthly === isMonthly) ? 'block' : 'none';
      });
    });
  });
});
</script>

