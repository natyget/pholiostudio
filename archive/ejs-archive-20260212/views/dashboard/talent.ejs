                  <div class="reach-viewer-count">Complete your profile to get discovered</div>
                </div>
              </div>
            <% } %>
          </div>
        </div>


        <!-- RECOMMENDED AGENCIES — #3, #14 -->
        <div class="agencies-card">
          <div class="section-header">
            <h3 class="section-title">Recommended Agencies</h3>
            <a href="/agencies" class="section-link">View All Agencies →</a>
          </div>
          <p class="section-subtitle">3 agencies match your profile — based on your location, experience, and look.</p>
          
          <div class="agencies-grid">
            <!-- Agency 1 — High Match -->
            <div class="agency-card">
              <div class="agency-match-badge high">⭐ 95% Match</div>
