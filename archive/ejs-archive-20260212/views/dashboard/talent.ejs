<% 
  // Safe profile extraction - handle null, undefined, arrays, and malformed objects
  let safeProfile = {};
  if (typeof profile !== 'undefined' && profile !== null) {
    if (Array.isArray(profile)) {
      safeProfile = profile.length > 0 ? profile[0] : {};
    } else if (typeof profile === 'object') {
      safeProfile = profile;
    }
  }
  
  // Debug: Log profile data in development
  if (typeof process !== 'undefined' && process.env && process.env.NODE_ENV === 'development') {
    console.log('[EJS Template] Profile data received:', {
      hasProfile: !!profile,
      profileType: typeof profile,
      isArray: Array.isArray(profile),
      safeProfileKeys: Object.keys(safeProfile).slice(0, 20),
      sampleValues: {
        city: safeProfile.city,
        phone: safeProfile.phone,
        height_cm: safeProfile.height_cm,
        gender: safeProfile.gender,
        date_of_birth: safeProfile.date_of_birth
      }
    });
  }
  
  // Helper function to safely extract values, preserving falsy values (false, 0, '')
  const safeValue = (val, def = '') => (val !== null && val !== undefined) ? val : def;
  
  // Helper function to safely extract JSON fields (handles both string and object)
  // Validates JSON strings before returning them to prevent template errors
  const safeJsonValue = (val, def = '[]') => {
    if (val === null || val === undefined) return def;
    
    // If it's already a string, validate it's valid JSON
    if (typeof val === 'string') {
      // Empty string should return default
      if (val.trim() === '') return def;
      try {
        // Validate by parsing - if successful, return original string
        JSON.parse(val);
        return val;
      } catch (e) {
        // Invalid JSON string - log warning in development and return default
        if (typeof process !== 'undefined' && process.env && process.env.NODE_ENV === 'development') {
          console.warn('[Template] Invalid JSON value:', val, e.message);
        }
        return def;
      }
    }
    
    // If it's an object/array, stringify it
    if (typeof val === 'object') {
      try {
        return JSON.stringify(val);
      } catch (e) {
        // Stringification failed - log warning and return default
        if (typeof process !== 'undefined' && process.env && process.env.NODE_ENV === 'development') {
          console.warn('[Template] Failed to stringify object:', e.message);
        }
        return def;
      }
    }
    
    // For other types (number, boolean, etc.), return default
    return def;
  };
  
  const rawMedia = (typeof images !== 'undefined' && images) ? images : [];
  const safeMedia = Array.isArray(rawMedia) ? rawMedia : [];
  const slug = safeProfile.slug || 'yourname';
  const effectiveShareUrl = (typeof shareUrl !== 'undefined') ? shareUrl : `https://pholio.me/${slug}`;
  const safeCompleteness = (typeof completeness !== 'undefined') ? completeness : {};
  
  // Onboarding state (variables passed from route - check existence before using)
  // These variables may not always be passed (e.g., error routes)
  // Use typeof to check existence, then assign to local consts with defaults
  const onboardingStage = safeProfile.onboarding_stage || 'draft';
  
  // Check and provide defaults for route variables that may not always be passed
  const hasShowOnboardingBanner = typeof showOnboardingBanner !== 'undefined';
  const showOnboardingBannerValue = hasShowOnboardingBanner ? showOnboardingBanner : false;
  const hasCanSubmit = typeof canSubmit !== 'undefined';
  const canSubmitValue = hasCanSubmit ? canSubmit : { ok: false, missing_fields: [], photo_count: 0, min_photos: 6 };
  
  // editDefaults with proper null/undefined checking (preserves falsy values like false, 0)
  const editDefaults = {
    city: safeValue(safeProfile.city),
    city_secondary: safeValue(safeProfile.city_secondary),
    height_cm: safeValue(safeProfile.height_cm),
    bio: safeValue(safeProfile.bio_raw),
    bio_curated: safeValue(safeProfile.bio_curated),
    phone: safeValue(safeProfile.phone),
    first_name: safeValue(safeProfile.first_name),
    last_name: safeValue(safeProfile.last_name),
    bust: safeValue(safeProfile.bust),
    waist: safeValue(safeProfile.waist),
    hips: safeValue(safeProfile.hips),
    shoe_size: safeValue(safeProfile.shoe_size),
    eye_color: safeValue(safeProfile.eye_color),
    hair_color: safeValue(safeProfile.hair_color),
    hair_length: safeValue(safeProfile.hair_length),
    skin_tone: safeValue(safeProfile.skin_tone),
    gender: safeValue(safeProfile.gender),
    date_of_birth: safeValue(safeProfile.date_of_birth),
    age: safeValue(safeProfile.age),
    weight: safeValue(safeProfile.weight_lbs || safeProfile.weight_kg || null),
    weight_unit: safeValue(safeProfile.weight_unit || (safeProfile.weight_kg ? 'kg' : 'lbs') || 'lbs'),
    weight_kg: safeValue(safeProfile.weight_kg),
    weight_lbs: safeValue(safeProfile.weight_lbs),
    dress_size: safeValue(safeProfile.dress_size),
    experience_level: safeValue(safeProfile.experience_level),
    training: safeValue(safeProfile.training),
    portfolio_url: safeValue(safeProfile.portfolio_url),
    instagram_handle: safeValue(safeProfile.instagram_handle),
    twitter_handle: safeValue(safeProfile.twitter_handle),
    tiktok_handle: safeValue(safeProfile.tiktok_handle),
    availability_travel: safeValue(safeProfile.availability_travel),
    availability_schedule: safeValue(safeProfile.availability_schedule),
    work_eligibility: safeValue(safeProfile.work_eligibility),
    work_status: safeValue(safeProfile.work_status),
    union_membership: safeValue(safeProfile.union_membership),
    ethnicity: safeValue(safeProfile.ethnicity),
    tattoos: safeValue(safeProfile.tattoos),
    piercings: safeValue(safeProfile.piercings),
    reference_name: safeValue(safeProfile.reference_name),
    reference_email: safeValue(safeProfile.reference_email),
    reference_phone: safeValue(safeProfile.reference_phone),
    emergency_contact_name: safeValue(safeProfile.emergency_contact_name),
    emergency_contact_phone: safeValue(safeProfile.emergency_contact_phone),
    emergency_contact_relationship: safeValue(safeProfile.emergency_contact_relationship),
    specialties: safeJsonValue(safeProfile.specialties, '[]'),
    experience_details: safeJsonValue(safeProfile.experience_details, '{}'),
    languages: safeJsonValue(safeProfile.languages, '[]'),
    comfort_levels: safeJsonValue(safeProfile.comfort_levels, '[]'),
    previous_representations: safeJsonValue(safeProfile.previous_representations, '[]')
  };
  
  // Ensure values is an object (handle null, undefined, and non-object types)
  const safeValues = (values && typeof values === 'object' && !Array.isArray(values)) ? values : {};
  const formValues = { ...editDefaults, ...safeValues };
  const _formErrors = (typeof formErrors !== 'undefined' && formErrors !== null) ? formErrors : {};
  const valueFor = (key) => {
    const val = formValues && formValues[key];
    return (val !== null && val !== undefined) ? val : '';
  };

  // Helper function to normalize image paths
  // Handles external URLs, local paths, and edge cases safely
  function normalizeImagePath(imagePath) {
    if (!imagePath || typeof imagePath !== 'string') return '';
    
    // Preserve external URLs (Google Photos, etc.)
    if (imagePath.startsWith('http://') || imagePath.startsWith('https://')) {
      return imagePath;
    }
    
    // Normalize local paths
    let normalized = imagePath;
    
    // Ensure leading slash
    if (!normalized.startsWith('/')) {
      normalized = '/' + normalized;
    }
    
    // If it doesn't start with /uploads/, extract filename and prepend /uploads/
    // This handles cases where paths might be stored without the /uploads/ prefix
    if (!normalized.startsWith('/uploads/')) {
      const filename = normalized.split('/').pop();
      if (filename) {
        normalized = '/uploads/' + filename;
      } else {
        // No filename found, return empty string
        return '';
      }
    }
    
    return normalized;
  }

  // Get hero image - check if it's a Google URL or user-uploaded
  const heroImagePath = safeProfile.hero_image_path;
  const heroImage = heroImagePath || (safeMedia.length > 0 ? safeMedia[0].path : null);
  const isGooglePhoto = heroImagePath && (heroImagePath.startsWith('http://') || heroImagePath.startsWith('https://'));
  const isUserUploadedPhoto = heroImagePath && !isGooglePhoto && heroImagePath.startsWith('/uploads/');
  
  // Get Google photo URL if available (for badge display)
  const googlePhotoURL = isGooglePhoto ? heroImagePath : null;

  const fieldError = (key) => (_formErrors[key] && _formErrors[key].length) ? _formErrors[key][0] : null;
  const fieldHasError = (key) => Boolean(fieldError(key));
  
  // Onboarding banner and submit button (shown when onboarding=1 and stage is draft/completing)
  const showOnboardingUI = showOnboardingBannerValue && (onboardingStage === 'draft' || onboardingStage === 'completing');

  // Use unified completeness calculation from backend (fixes split-brain problem)
  // The route handler passes the completeness object with sections calculated by calculateProfileCompleteness()
  const sectionStatuses = safeCompleteness.sections || {
    personalInfo: { status: 'incomplete', message: 'Complete profile' },
    physicalProfile: { status: 'incomplete', message: 'Complete profile' },
    experienceTraining: { status: 'incomplete', message: 'Complete profile' },
    skillsLifestyle: { status: 'incomplete', message: 'Complete profile' },
    comfortBoundaries: { status: 'incomplete', message: 'Complete profile' },
    availabilityLocations: { status: 'incomplete', message: 'Complete profile' },
    socialPortfolio: { status: 'incomplete', message: 'Complete profile' },
    referencesEmergency: { status: 'incomplete', message: 'Complete profile' }
  };
  
  // Applications & Matches is a display section, not a completeness section - always complete
  if (!sectionStatuses.applicationsMatches) {
    sectionStatuses.applicationsMatches = { status: 'complete', message: 'View applications' };
  }
  %>

  <% if (showOnboardingUI) { %>
    <!-- Onboarding Banner -->
    <div class="onboarding-banner" style="background: linear-gradient(135deg, rgba(201, 165, 90, 0.1) 0%, rgba(201, 165, 90, 0.05) 100%); border: 1px solid rgba(201, 165, 90, 0.3); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; margin-top: 1rem;">
      <div style="display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1rem;">
        <div style="font-size: 1.5rem; flex-shrink: 0;">📋</div>
        <div style="flex: 1;">
          <h3 style="font-size: 1.125rem; font-weight: 600; color: var(--text-primary, #fff); margin-bottom: 0.5rem;">
            Complete your profile to submit
          </h3>
          <p style="font-size: 0.9375rem; color: var(--text-secondary, rgba(255, 255, 255, 0.8)); line-height: 1.6; margin-bottom: 1rem;">
            Fill out all required fields and upload at least <%= canSubmitValue.min_photos %> photos to submit your profile for AI analysis.
          </p>
          <% if (!canSubmitValue.ok) { %>
            <div style="padding: 0.75rem; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 6px; margin-bottom: 1rem;">
              <p style="font-size: 0.875rem; color: rgba(255, 255, 255, 0.9); margin-bottom: 0.25rem; font-weight: 500;">
                Still missing:
              </p>
              <ul style="margin: 0; padding-left: 1.25rem; font-size: 0.875rem; color: rgba(255, 255, 255, 0.8);">
                <% if (canSubmitValue.missing_fields && canSubmitValue.missing_fields.length > 0) { %>
                  <% canSubmitValue.missing_fields.forEach(field => { %>
                    <li><%= field %></li>
                  <% }); %>
                <% } %>
                <% if (!canSubmitValue.has_enough_photos) { %>
                  <li>Minimum <%= canSubmitValue.min_photos %> photos (you have <%= canSubmitValue.photo_count %>)</li>
                <% } %>
              </ul>
            </div>
          <% } %>
          <form method="post" action="/dashboard/talent/onboarding/submit" style="display: inline-block;">
            <button 
              type="submit" 
              class="button button-primary"
              <%= !canSubmitValue.ok ? 'disabled style="opacity: 0.6; cursor: not-allowed;"' : '' %>
              onclick="return confirm('Submit your profile for AI analysis? This will trigger the processing pipeline.')">
              Submit Profile for Processing
            </button>
          </form>
        </div>
      </div>
    </div>
  <% } %>
  <!-- APPLICATION INTERFACE -->
  <div class="dashboard-shell">
    
    <!-- 1. SIDEBAR NAVIGATION (Dark) -->
    <aside class="app-sidebar">
      <div class="sidebar-logo">
        <div class="sidebar-logo-icon">P</div>
        <span class="sidebar-logo-text">Pholio</span>
      </div>
      
      <nav class="sidebar-nav">
        <div class="nav-section">
          <div class="nav-item active">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            <span>Overview</span>
          </div>
          <a href="/agencies" class="nav-item">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span>Agencies</span>
          </a>
          <a href="#apps-section" class="nav-item">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <span>Applications</span>
          </a>
          <a href="#portfolio-section" class="nav-item">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <span>Portfolio</span>
          </a>
          <a href="#" class="nav-item">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <span>Messages</span>
            <span class="nav-badge">0</span>
          </a>
          <a href="#dossier-section" class="nav-item">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>Profile</span>
          </a>
        </div>
      </nav>

      
      <!-- Sidebar Footer with Dropdown -->
      <div class="sidebar-footer">
        <div class="sidebar-profile" id="profile-dropdown-trigger" onclick="toggleSidebarDropdown()">
          <div class="sidebar-profile-avatar">
            <% if (safeProfile.hero_image_path) { %>
              <img src="<%= normalizeImagePath(safeProfile.hero_image_path) %>" alt="">
            <% } else if (safeMedia && safeMedia.length > 0) { %>
              <img src="<%= normalizeImagePath(safeMedia[0].path) %>" alt="">
            <% } else { %>
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#1e293b;color:#94a3b8;font-weight:600;"><%= (safeProfile.first_name || 'U')[0] %></div>
            <% } %>
          </div>
          <div class="sidebar-profile-info">
            <div class="sidebar-profile-name"><%= safeProfile.first_name || 'Your' %> <%= (safeProfile.last_name || 'Name')[0] %>.</div>
            <div class="sidebar-profile-role">Talent</div>
          </div>
          <svg class="sidebar-profile-chevron" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </div>
        
        <!-- Dropdown Menu -->
        <div class="sidebar-dropdown" id="sidebar-dropdown" hidden>
          <div class="dropdown-section">
            <a href="/dashboard/settings" class="dropdown-item">
              <span class="dropdown-icon">⚙️</span>
              <span>Settings</span>
            </a>
            <a href="/dashboard/settings#notifications" class="dropdown-item">
              <span class="dropdown-icon">🔔</span>
              <span>Notifications</span>
            </a>
            <a href="/dashboard/settings#billing" class="dropdown-item">
              <span class="dropdown-icon">💳</span>
              <span>Billing</span>
            </a>
          </div>
          
          <div class="dropdown-divider"></div>
          
          <div class="dropdown-section">
            <a href="/" class="dropdown-item">
              <span class="dropdown-icon">🏠</span>
              <span>Back to Website</span>
            </a>
            <a href="/agencies" class="dropdown-item">
              <span class="dropdown-icon">🔍</span>
              <span>Browse Agencies</span>
            </a>
            <a href="/help" class="dropdown-item">
              <span class="dropdown-icon">❓</span>
              <span>Help & Support</span>
            </a>
          </div>
          
          <div class="dropdown-divider"></div>
          
          <a href="/auth/logout" class="dropdown-item dropdown-logout">
            <span class="dropdown-icon">🚪</span>
            <span>Sign Out</span>
          </a>
        </div>
      </div>
    </aside>


    <!-- 2. MAIN CANVAS -->
    <main class="app-canvas">
      <div class="canvas-content">
        
        <!-- WELCOME HEADER — Large & Prominent -->
        <div class="welcome-banner" style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 40px; padding-top: 12px;">
          <div>
            <p style="font-size: 13px; font-weight: 600; color: #C9A55A; text-transform: uppercase; letter-spacing: 0.12em; margin: 0 0 10px;">
              <% 
                const hour = new Date().getHours();
                let greeting = 'Good evening';
                if (hour < 12) greeting = 'Good morning';
                else if (hour < 17) greeting = 'Good afternoon';
              %>
              <%= greeting %>
            </p>
            <h1 style="font-family: var(--font-serif); font-size: 42px; font-weight: 700; color: #0f172a; margin: 0 0 8px; letter-spacing: -0.03em; line-height: 1.1;">
              <%= safeProfile.first_name || 'Welcome' %>
            </h1>
            <p style="font-size: 16px; color: #64748b; margin: 0;">
              <span id="current-date"></span> · <strong style="color: #C9A55A;"><%= safeCompleteness.percentage || 0 %>%</strong> profile complete
            </p>
          </div>
          
          <div style="display: flex; gap: 12px; padding-top: 8px;">
            <a href="/talent/<%= safeProfile.id || '' %>" target="_blank" style="background: #ffffff; border: 1px solid #e2e8f0; color: #0f172a; font-size: 14px; font-weight: 600; padding: 12px 22px; border-radius: 10px; text-decoration: none; transition: all 0.2s ease;">
              View Profile
            </a>
            <a href="/agencies" style="background: #C9A55A; color: #ffffff; font-size: 14px; font-weight: 600; padding: 12px 22px; border-radius: 10px; text-decoration: none; transition: all 0.2s ease;">
              Browse Agencies
            </a>
          </div>
        </div>

        
        <script>
          document.getElementById('current-date').textContent = new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' });
        </script>


        
        <!-- PROFILE REACH — Stats without duplicate % -->
        <div class="reach-card">
          <div class="reach-header">
            <h2>Your Profile Reach</h2>
            <span class="reach-period">This Week</span>
          </div>
          
          <div class="reach-stats" style="grid-template-columns: repeat(3, 1fr);">
            <% if ((typeof profileViews !== 'undefined' ? profileViews : 0) === 0) { %>
              <!-- Zero-state with illustration -->
              <div class="reach-stat" style="background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-color: #f59e0b;">
                <div class="reach-stat-value" style="font-size: 28px;">🚀</div>
                <div class="reach-stat-label">Start Here</div>
                <div class="reach-stat-hint" style="color: #92400e;">Complete your profile</div>
              </div>
            <% } else { %>
              <div class="reach-stat">
                <div class="reach-stat-value"><%= typeof profileViews !== 'undefined' ? profileViews : 0 %></div>
                <div class="reach-stat-label">Views</div>
                <div class="reach-stat-hint">this week</div>
              </div>
            <% } %>
            <div class="reach-stat">
              <div class="reach-stat-value"><%= typeof agencyViews !== 'undefined' ? agencyViews : 0 %></div>
              <div class="reach-stat-label">Agencies</div>
              <div class="reach-stat-hint">viewed you</div>
            </div>
            <div class="reach-stat">
              <div class="reach-stat-value"><%= typeof shortlistCount !== 'undefined' ? shortlistCount : 0 %></div>
              <div class="reach-stat-label">Shortlists</div>
              <div class="reach-stat-hint">this month</div>
            </div>
          </div>

          
          <!-- #9 — Top Viewers with Social Proof -->
          <div class="reach-viewers">
            <div class="reach-viewers-title">Top Viewers</div>
            <% if ((typeof profileViews !== 'undefined' && profileViews > 0) || false) { %>
              <div class="reach-viewer">
                <div class="reach-viewer-avatar">E</div>
                <div class="reach-viewer-info">
                  <div class="reach-viewer-name">Elite Models NYC</div>
