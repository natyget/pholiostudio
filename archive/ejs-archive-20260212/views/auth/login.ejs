<%- include('../partials/forms', { errors, values }) %>
<% const _errors=(typeof errors==='object' && errors) ? errors : {}; const _values=(typeof values==='object' && values) ? values : {}; const valueFor=(name, fallback='')=> {
  if (Object.prototype.hasOwnProperty.call(_values, name) && _values[name] != null) {
    return _values[name];
  }
  return fallback;
};

const fieldError = (name) => {
  const v = _errors[name];
  if (!v) return '';
  return Array.isArray(v) ? v[0] : v;
};
%>
<section class="auth-page">
  <div class="auth-page__visual">
    <div class="auth-page__visual-content">
      <span class="auth-page__visual-badge">Sign In</span>
      <h1 class="auth-page__visual-headline">
        <span class="auth-page__visual-headline-fashion">Welcome back.</span>
        <span class="auth-page__visual-headline-ai">Your editorial studio.</span>
      </h1>
      <p class="auth-page__visual-tagline">Access your dashboard, refresh your comp card, and keep your book in sync with every update.</p>
      <div class="auth-page__visual-accent"></div>
    </div>
  </div>
  
  <div class="auth-page__form">
    <div class="auth-page__form-container">
      <div class="auth-page__form-header">
        <h2 class="auth-page__form-title">Sign in</h2>
        <p class="auth-page__form-subtitle">Enter your credentials to continue</p>
      </div>
      
      <div class="auth-card">
        <!-- CRITICAL: onsubmit="return false" prevents ANY native browser submission -->
        <form id="login-form" autocomplete="off" onsubmit="handleEmailLogin(event); return false;">
          <input type="hidden" id="next" value="<%= valueFor('next', '') %>">
          
          <div class="form-field <%= fieldError('email') ? 'has-error' : '' %>">
            <label for="email">Email</label>
            <input id="email" type="email" autocomplete="email" value="<%= valueFor('email', '') %>" required>
            <% if (fieldError('email')) { %>
              <p class="field-error"><%= fieldError('email') %></p>
            <% } %>
          </div>
          
          <div class="form-field <%= fieldError('password') ? 'has-error' : '' %>">
            <label for="password">Password</label>
            <input id="password" type="password" autocomplete="current-password" required>
            <% if (fieldError('password')) { %>
              <p class="field-error"><%= fieldError('password') %></p>
            <% } %>
          </div>
          
          <div id="auth-error-message" class="auth-error field-error" style="display: none; margin-bottom: 1rem; color: #d00;"></div>

          <button type="submit" id="email-submit-btn" class="button button-primary button-block">
            Sign in
          </button>
        </form>
        
        <div class="auth-divider">
          <span>or</span>
        </div>
        
        <!-- CRITICAL: type="button" ensures this NEVER triggers form submission -->
        <button type="button" id="google-signin-btn" class="button button-google button-block" onclick="handleGoogleLogin(event)">
          <svg width="18" height="18" viewBox="0 0 18 18" style="margin-right: 8px; vertical-align: middle; pointer-events: none;">
            <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/>
            <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332C2.438 15.983 5.482 18 9 18z"/>
            <path fill="#FBBC05" d="M3.964 10.707c-.18-.54-.282-1.117-.282-1.707s.102-1.167.282-1.707V4.961H.957C.348 6.175 0 7.55 0 9s.348 2.825.957 4.039l3.007-2.332z"/>
            <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.482 0 2.438 2.017.957 4.961L3.964 7.293C4.672 5.163 6.656 3.58 9 3.58z"/>
          </svg>
          Sign in with Google
        </button>
        
        <p class="auth-switch">Need an account? <a href="/apply">Start Creating</a>.</p>
      </div>
    </div>
  </div>
</section>

<script>
// --- UI Helpers ---

function setLoading(isLoading, isGoogle = false) {
  const emailBtn = document.getElementById('email-submit-btn');
  const googleBtn = document.getElementById('google-signin-btn');
  
  if (isLoading) {
    if (isGoogle) {
      if (googleBtn) {
        googleBtn.disabled = true;
        googleBtn.innerHTML = 'Signing in...';
      }
      if (emailBtn) emailBtn.disabled = true; // Disable other button too to prevent double submit
    } else {
      if (emailBtn) {
        emailBtn.disabled = true;
        emailBtn.textContent = 'Signing in...';
      }
      if (googleBtn) googleBtn.disabled = true;
    }
  } else {
    // Reset buttons
    if (emailBtn) {
      emailBtn.disabled = false;
      emailBtn.textContent = 'Sign in';
    }
    if (googleBtn) {
      googleBtn.disabled = false;
      googleBtn.innerHTML = `
        <svg width="18" height="18" viewBox="0 0 18 18" style="margin-right: 8px; vertical-align: middle; pointer-events: none;">
          <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/>
          <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332C2.438 15.983 5.482 18 9 18z"/>
          <path fill="#FBBC05" d="M3.964 10.707c-.18-.54-.282-1.117-.282-1.707s.102-1.167.282-1.707V4.961H.957C.348 6.175 0 7.55 0 9s.348 2.825.957 4.039l3.007-2.332z"/>
          <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.482 0 2.438 2.017.957 4.961L3.964 7.293C4.672 5.163 6.656 3.58 9 3.58z"/>
        </svg>
        Sign in with Google
      `;
    }
  }
}

function showError(msg) {
  const el = document.getElementById('auth-error-message');
  if (el) {
    el.style.display = 'block';
    el.textContent = msg;
  } else {
    alert(msg);
  }
}

function hideError() {
  const el = document.getElementById('auth-error-message');
  if (el) el.style.display = 'none';
}

// --- Auth Handling ---

async function getFirebaseAuth() {
  if (window.FirebaseAuth) return window.FirebaseAuth;
  
  return new Promise((resolve) => {
    let attempts = 0;
    const i = setInterval(() => {
      attempts++;
      if (window.FirebaseAuth) {
        clearInterval(i);
        resolve(window.FirebaseAuth);
      }
      if (attempts > 50) {
        clearInterval(i);
        resolve(null);
      }
    }, 100);
  });
}

async function submitToServer(idToken) {
  console.log('[Login] Submitting to server with token:', idToken ? 'PRESENT' : 'MISSING');
  
  try {
    const nextVal = document.getElementById('next')?.value || '';
    const emailVal = document.getElementById('email')?.value || '';
    
    // JSON POST to /login
    const res = await fetch('/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include', // Important for cookies/session
      body: JSON.stringify({
        firebase_token: idToken,
        email: emailVal, // Optional, usage depends on backend
        next: nextVal
      })
    });
    
    const data = await res.json().catch(() => ({}));
    
    if (res.ok) {
      console.log('[Login] Server success. Redirecting...');
      window.location.href = data.redirect || '/dashboard/talent';
    } else {
      console.error('[Login] Server error:', data);
      showError(data.error || data.message || 'Login failed on server.');
      setLoading(false);
    }
  } catch (err) {
    console.error('[Login] Network error:', err);
    showError('Network error connecting to login server.');
    setLoading(false);
  }
}

// --- Global Handlers (Attached via onclick/onsubmit) ---

window.handleEmailLogin = async function(e) {
  if (e) e.preventDefault();
  hideError();
  
  const email = document.getElementById('email').value;
  const password = document.getElementById('password').value;
  
  if (!email || !password) {
    showError('Please enter both email and password.');
    return;
  }
  
  setLoading(true, false);
  
  const fb = await getFirebaseAuth();
  if (!fb) {
    showError('Authentication system is not ready. Please refresh.');
    setLoading(false);
    return;
  }
  
  try {
    console.log('[Login] Signing in with Email...');
    const userCred = await fb.signIn(email, password);
    const token = await userCred.user.getIdToken();
    await submitToServer(token);
  } catch (err) {
    console.error('[Login] Email Auth Error:', err);
    showError(translateFirebaseError(err));
    setLoading(false);
  }
};

window.handleGoogleLogin = async function(e) {
  if (e) {
    e.preventDefault(); 
    e.stopPropagation(); // Stop any parent listeners
  }
  hideError();
  
  console.log('[Login] Google button clicked.');
  setLoading(true, true);
  
  const fb = await getFirebaseAuth();
  if (!fb) {
    showError('Authentication system is not ready. Please refresh.');
    setLoading(false);
    return;
  }
  
  try {
    console.log('[Login] Starting Google Popup...');
    // Force Popup flow (false)
    const userCred = await fb.signInWithGoogle(false);
    
    if (userCred && userCred.user) {
      console.log('[Login] Google Popup Success.');
      const token = await userCred.user.getIdToken();
      // Optional: Prefill email field for visual consistency
      if (userCred.user.email) {
        const emailEl = document.getElementById('email');
        if (emailEl) emailEl.value = userCred.user.email;
      }
      await submitToServer(token);
    } else {
      throw new Error('No user returned from Google Sign-In.');
    }
  } catch (err) {
    console.error('[Login] Google Auth Error:', err);
    
    // Handle Popup Closed
    if (err.code === 'auth/popup-closed-by-user') {
       console.log('[Login] Popup closed. Resetting UI.');
       setLoading(false);
       // Optional: Don't show an error message for voluntary closure
       return; 
    }
    
    // Handle Popup Blocked -> Suggest fix
    if (err.code === 'auth/popup-blocked') {
      showError('Popup was blocked. Please allow popups for this site.');
      setLoading(false);
      return;
    }
    
    showError(translateFirebaseError(err));
    setLoading(false);
  }
};

function translateFirebaseError(err) {
  if (err.code === 'auth/invalid-credential' || err.code === 'auth/wrong-password') return 'Invalid email or password.';
  if (err.code === 'auth/user-not-found') return 'No account found with this email.';
  if (err.code === 'auth/too-many-requests') return 'Too many attempts. Try again later.';
  return err.message || 'Login failed.';
}

// Minimal initialization logging
document.addEventListener('DOMContentLoaded', () => {
    console.log('[Login] Page Ready. waiting for Firebase...');
    getFirebaseAuth().then(fb => {
        console.log('[Login] Firebase Detected:', !!fb);
    });
});
</script>
