<!-- Onboarding Status Page - Phase C Job Status -->
<section class="onboarding-status">
  <div class="onboarding-status__container">
    <div class="onboarding-status__header">
      <h1 class="onboarding-status__title">Processing Your Profile</h1>
      <p class="onboarding-status__subtitle"><%= statusMessage %></p>
    </div>
    
    <!-- Progress Bar -->
    <div class="progress-section">
      <div class="progress-bar">
        <div class="progress-bar__fill" style="width: <%= progress %>%"></div>
      </div>
      <div class="progress-text"><%= progress %>% Complete</div>
    </div>
    
    <!-- Status Details -->
    <div class="status-details">
      <h2 class="status-details__title">Current Status</h2>
      <ul class="status-list">
        <% statusDetails.forEach((detail, index) => { %>
          <li class="status-item <%= index === 0 ? 'status-item--active' : '' %>">
            <span class="status-item__icon">
              <% if (index === 0 && onboardingStage === 'processing') { %>
                ⏳
              <% } else if (onboardingStage === 'processed') { %>
                ✅
              <% } else { %>
                ⏸️
              <% } %>
            </span>
            <span class="status-item__text"><%= detail %></span>
          </li>
        <% }); %>
      </ul>
    </div>
    
    <!-- Timeline Info -->
    <% if (onboardingStage === 'submitted' || onboardingStage === 'processing') { %>
      <div class="status-info">
        <p class="status-info__text">
          This page will automatically refresh every few seconds. 
          <%= onboardingStage === 'submitted' ? 'Processing will begin shortly.' : 'Your profile is being analyzed by our AI systems.' %>
        </p>
      </div>
    <% } %>
    
    <% if (onboardingStage === 'processed') { %>
      <div class="status-complete">
        <p class="status-complete__text">Your profile has been processed successfully! Redirecting to dashboard...</p>
      </div>
    <% } %>
  </div>
</section>

<style>
  .onboarding-status {
    padding: 3rem 1rem;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .onboarding-status__container {
    max-width: 600px;
    width: 100%;
  }
  
  .onboarding-status__header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .onboarding-status__title {
    font-size: 2rem;
    font-weight: 600;
    color: var(--text-primary, #fff);
    margin-bottom: 0.5rem;
    font-family: var(--font-serif, 'Noto Serif Display', serif);
  }
  
  .onboarding-status__subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary, rgba(255, 255, 255, 0.8));
  }
  
  .progress-section {
    margin-bottom: 3rem;
  }
  
  .progress-bar {
    width: 100%;
    height: 8px;
    background: var(--bg-surface-elevated, rgba(255, 255, 255, 0.1));
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }
  
  .progress-bar__fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-gold, #c9a55a) 0%, rgba(201, 165, 90, 0.8) 100%);
    transition: width 0.3s ease;
  }
  
  .progress-text {
    text-align: center;
    font-size: 0.875rem;
    color: var(--text-secondary, rgba(255, 255, 255, 0.7));
    font-weight: 500;
  }
  
  .status-details {
    background: var(--bg-surface, rgba(255, 255, 255, 0.05));
    border: 1px solid var(--border-color, rgba(255, 255, 255, 0.1));
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
  }
  
  .status-details__title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary, #fff);
    margin-bottom: 1.5rem;
  }
  
  .status-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .status-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem;
    border-radius: 6px;
    transition: background 0.2s;
  }
  
  .status-item--active {
    background: rgba(201, 165, 90, 0.1);
  }
  
  .status-item__icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }
  
  .status-item__text {
    font-size: 0.9375rem;
    color: var(--text-primary, #fff);
  }
  
  .status-info {
    text-align: center;
    padding: 1.5rem;
    background: rgba(201, 165, 90, 0.05);
    border: 1px solid rgba(201, 165, 90, 0.2);
    border-radius: 8px;
  }
  
  .status-info__text {
    font-size: 0.875rem;
    color: var(--text-secondary, rgba(255, 255, 255, 0.8));
    line-height: 1.6;
  }
  
  .status-complete {
    text-align: center;
    padding: 2rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
  }
  
  .status-complete__text {
    font-size: 1rem;
    color: var(--text-primary, #fff);
    font-weight: 500;
  }
</style>

<script>
  // Auto-refresh every 5 seconds if not processed
  (function() {
    const isProcessed = <%= isProcessed ? 'true' : 'false' %>;
    
    if (!isProcessed) {
      // Refresh page every 5 seconds
      setTimeout(function() {
        window.location.reload();
      }, 5000);
    } else {
      // Redirect to dashboard after 2 seconds if processed
      setTimeout(function() {
        window.location.href = '/dashboard/talent';
      }, 2000);
    }
  })();
</script>
