<!-- Application Detail Drawer -->
<div class="agency-detail-drawer" id="application-detail-drawer" style="display: none;">
  <div class="agency-detail-drawer__overlay"></div>
  <div class="agency-detail-drawer__content">
    <!-- Sticky Header -->
    <div class="agency-detail-drawer__header">
      <div class="agency-detail-drawer__header-left">
        <a href="/dashboard/agency/applicants" class="agency-detail-drawer__back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          Back to Inbox
        </a>
        <div class="agency-detail-drawer__header-name-group">
          <h1 class="agency-detail-drawer__name" id="detail-drawer-name">Loading...</h1>
          <div class="agency-detail-drawer__badges" id="detail-drawer-badges">
            <!-- Badges will be inserted here -->
          </div>
        </div>
      </div>
      <div class="agency-detail-drawer__header-right">
        <div class="agency-detail-drawer__header-actions">
          <a 
            href="#" 
            class="agency-detail-drawer__comp-card-btn" 
            id="detail-drawer-comp-card-link"
            target="_blank"
            style="display: none;"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <line x1="9" y1="3" x2="9" y2="21"/>
            </svg>
            Comp Card
          </a>
          <button 
            class="agency-detail-drawer__accept-btn" 
            id="detail-drawer-accept"
            style="display: none;"
          >
            Accept Application
          </button>
        </div>
        <button class="agency-detail-drawer__close" id="detail-drawer-close" aria-label="Close">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Body with Split-Screen Layout -->
    <div class="agency-detail-drawer__body" id="detail-drawer-body">
      <!-- Content will be dynamically inserted here with split-screen layout -->
    </div>
  </div>
</div>

