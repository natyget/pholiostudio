<!-- My Applicants Page Header -->
<%
  const safePipelineCounts = (typeof pipelineCounts !== 'undefined' && pipelineCounts) ? pipelineCounts : {
    all: 0,
    new: 0,
    pending: 0,
    'under-review': 0,
    accepted: 0,
    declined: 0,
    archived: 0
  };
  const currentStatus = (typeof filters !== 'undefined' && filters.status) ? filters.status : 'all';
  const hasApplicants = safePipelineCounts.all > 0;
%>
<section class="agency-applicants-header">
  <div class="agency-applicants-header__content">
    <!-- Main Row: Title + Search + Actions -->
    <div class="agency-applicants-header__main-row">
      <div class="agency-applicants-header__title-group">
        <h1 class="agency-applicants-header__title">Inbox</h1>
        <p class="agency-applicants-header__subtitle">Manage incoming applications.</p>
      </div>
      
      <div class="agency-applicants-header__actions-group">
        <div class="agency-applicants-header__search">
          <svg class="agency-applicants-header__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
          <input 
            type="text" 
            placeholder="Search applicants by name, location..." 
            class="agency-applicants-header__search-input"
            id="applicants-search-input"
            value="<%= typeof filters !== 'undefined' && filters.search ? filters.search : '' %>"
          />
        </div>
        
        <% if (hasApplicants) { %>
          <button class="agency-applicants-header__filters-btn" id="applicants-filters-btn" aria-label="Open filters">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
            </svg>
            Filters
          </button>
        <% } %>
      </div>
    </div>
    
    <!-- Quick Stats Cards (only show if there are applicants) -->
    <% if (hasApplicants) { %>
      <div class="agency-applicants-header__stats">
        <div class="applicants-stat-card">
          <div class="applicants-stat-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <div class="applicants-stat-card__content">
            <div class="applicants-stat-card__value"><%= safePipelineCounts.all %></div>
            <div class="applicants-stat-card__label">Total Applicants</div>
          </div>
        </div>
        
        <div class="applicants-stat-card applicants-stat-card--highlight">
          <div class="applicants-stat-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="applicants-stat-card__content">
            <div class="applicants-stat-card__value"><%= safePipelineCounts.pending + safePipelineCounts['under-review'] %></div>
            <div class="applicants-stat-card__label">Needs Review</div>
          </div>
        </div>
        
        <div class="applicants-stat-card">
          <div class="applicants-stat-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <div class="applicants-stat-card__content">
            <div class="applicants-stat-card__value"><%= safePipelineCounts.accepted %></div>
            <div class="applicants-stat-card__label">Accepted</div>
          </div>
        </div>
      </div>
    <% } %>
    
    <!-- Status Tabs Row (only show if there are applicants) -->
    <% if (hasApplicants) { %>
      <div class="agency-applicants-header__status-row">
        <div class="applicants-status-tabs">
          <button 
            class="applicants-status-tab <%= currentStatus === 'all' ? 'applicants-status-tab--active' : '' %>" 
            data-status="all"
            title="View all applicants"
          >
            All (<%= safePipelineCounts.all %>)
          </button>
          <button 
            class="applicants-status-tab <%= currentStatus === 'new' ? 'applicants-status-tab--active' : '' %>" 
            data-status="new"
            title="New applications that haven't been viewed"
          >
            New (<%= safePipelineCounts.new %>)
          </button>
          <button 
            class="applicants-status-tab <%= currentStatus === 'pending' ? 'applicants-status-tab--active' : '' %>" 
            data-status="pending"
            title="Pending review"
          >
            Pending (<%= safePipelineCounts.pending %>)
          </button>
          <button 
            class="applicants-status-tab <%= currentStatus === 'under-review' ? 'applicants-status-tab--active' : '' %>" 
            data-status="under-review"
            title="Currently under review"
          >
            Under Review (<%= safePipelineCounts['under-review'] %>)
          </button>
          <button 
            class="applicants-status-tab <%= currentStatus === 'accepted' ? 'applicants-status-tab--active' : '' %>" 
            data-status="accepted"
            title="Accepted applicants"
          >
            Accepted (<%= safePipelineCounts.accepted %>)
          </button>
        </div>
        
        <div class="agency-applicants-header__view-toggle" role="group" aria-label="View mode">
          <button 
            type="button" 
            class="agency-applicants-header__view-btn agency-applicants-header__view-btn--active" 
            data-view="list"
            aria-label="List view"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="8" y1="6" x2="21" y2="6"/>
              <line x1="8" y1="12" x2="21" y2="12"/>
              <line x1="8" y1="18" x2="21" y2="18"/>
              <line x1="3" y1="6" x2="3.01" y2="6"/>
              <line x1="3" y1="12" x2="3.01" y2="12"/>
              <line x1="3" y1="18" x2="3.01" y2="18"/>
            </svg>
            <span class="agency-applicants-header__view-label">List</span>
          </button>
          <button 
            type="button" 
            class="agency-applicants-header__view-btn" 
            data-view="gallery"
            aria-label="Gallery view"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <span class="agency-applicants-header__view-label">Gallery</span>
          </button>
          <button 
            type="button" 
            class="agency-applicants-header__view-btn" 
            data-view="table"
            aria-label="Table view"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/>
            </svg>
            <span class="agency-applicants-header__view-label">Table</span>
          </button>
        </div>
      </div>
    <% } %>
  </div>
</section>

