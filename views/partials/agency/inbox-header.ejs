<!-- My Applicants Page Header -->
<%
  const safePipelineCounts = (typeof pipelineCounts !== 'undefined' && pipelineCounts) ? pipelineCounts : {
    all: 0,
    new: 0,
    pending: 0,
    'under-review': 0,
    accepted: 0,
    declined: 0,
    archived: 0
  };
  const currentStatus = (typeof filters !== 'undefined' && filters.status) ? filters.status : 'all';
%>
<section class="agency-applicants-header">
  <div class="agency-applicants-header__content">
    <!-- Row 1: Title -->
    <div class="agency-applicants-header__row agency-applicants-header__row--title">
      <div class="agency-applicants-header__title-group">
        <h1 class="agency-applicants-header__title">My Applicants</h1>
        <p class="agency-applicants-header__subtitle"><span id="applicants-total-count"><%= safePipelineCounts.all %></span> total applicants</p>
      </div>
    </div>
    
    <!-- Row 2: Search, Filters, View Toggle -->
    <div class="agency-applicants-header__row agency-applicants-header__row--controls">
      <div class="agency-applicants-header__search-group">
        <div class="agency-applicants-header__search">
          <svg class="agency-applicants-header__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
          <input 
            type="text" 
            placeholder="Search applicants..." 
            class="agency-applicants-header__search-input"
            id="applicants-search-input"
          />
        </div>
        
        <button class="agency-applicants-header__filters-btn" id="applicants-filters-btn" aria-label="Open filters">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
          </svg>
          Filters
        </button>
      </div>
      
      <div class="agency-applicants-header__view-toggle" role="group" aria-label="View mode">
        <button 
          type="button" 
          class="agency-applicants-header__view-btn agency-applicants-header__view-btn--active" 
          data-view="list"
          aria-label="List view"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="8" y1="6" x2="21" y2="6"/>
            <line x1="8" y1="12" x2="21" y2="12"/>
            <line x1="8" y1="18" x2="21" y2="18"/>
            <line x1="3" y1="6" x2="3.01" y2="6"/>
            <line x1="3" y1="12" x2="3.01" y2="12"/>
            <line x1="3" y1="18" x2="3.01" y2="18"/>
          </svg>
          <span class="agency-applicants-header__view-label">List</span>
        </button>
        <button 
          type="button" 
          class="agency-applicants-header__view-btn" 
          data-view="gallery"
          aria-label="Gallery view"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <span class="agency-applicants-header__view-label">Gallery</span>
        </button>
        <button 
          type="button" 
          class="agency-applicants-header__view-btn" 
          data-view="table"
          aria-label="Table view"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/>
          </svg>
          <span class="agency-applicants-header__view-label">Table</span>
        </button>
      </div>
    </div>
    
    <!-- Row 3: Status Pills -->
    <div class="agency-applicants-header__row agency-applicants-header__row--status">
      <div class="applicants-status-pills">
        <button 
          class="applicants-status-pill <%= currentStatus === 'all' ? 'applicants-status-pill--active' : '' %>" 
          data-status="all"
        >
          <span class="applicants-status-pill__label">All</span>
          <span class="applicants-status-pill__count"><%= safePipelineCounts.all %></span>
        </button>
        <button 
          class="applicants-status-pill <%= currentStatus === 'new' ? 'applicants-status-pill--active' : '' %>" 
          data-status="new"
        >
          <span class="applicants-status-pill__label">New</span>
          <span class="applicants-status-pill__count"><%= safePipelineCounts.new %></span>
        </button>
        <button 
          class="applicants-status-pill <%= currentStatus === 'pending' ? 'applicants-status-pill--active' : '' %>" 
          data-status="pending"
        >
          <span class="applicants-status-pill__label">Pending</span>
          <span class="applicants-status-pill__count"><%= safePipelineCounts.pending %></span>
        </button>
        <button 
          class="applicants-status-pill <%= currentStatus === 'under-review' ? 'applicants-status-pill--active' : '' %>" 
          data-status="under-review"
        >
          <span class="applicants-status-pill__label">Under Review</span>
          <span class="applicants-status-pill__count"><%= safePipelineCounts['under-review'] %></span>
        </button>
        <button 
          class="applicants-status-pill <%= currentStatus === 'accepted' ? 'applicants-status-pill--active' : '' %>" 
          data-status="accepted"
        >
          <span class="applicants-status-pill__label">Accepted</span>
          <span class="applicants-status-pill__count"><%= safePipelineCounts.accepted %></span>
        </button>
        <button 
          class="applicants-status-pill <%= currentStatus === 'declined' ? 'applicants-status-pill--active' : '' %>" 
          data-status="declined"
        >
          <span class="applicants-status-pill__label">Declined</span>
          <span class="applicants-status-pill__count"><%= safePipelineCounts.declined %></span>
        </button>
        <button 
          class="applicants-status-pill <%= currentStatus === 'archived' ? 'applicants-status-pill--active' : '' %>" 
          data-status="archived"
        >
          <span class="applicants-status-pill__label">Archived</span>
          <span class="applicants-status-pill__count"><%= safePipelineCounts.archived %></span>
        </button>
      </div>
    </div>
  </div>
</section>

