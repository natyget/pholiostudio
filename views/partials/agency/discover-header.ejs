<!-- Discover Hero Section - Editorial Luxury × Command Center -->
<section class="discover-hero">
  <div class="discover-hero__content">
    <!-- Title & Subtitle -->
    <div class="discover-hero__intro">
      <h1 class="discover-hero__title discover-title">Scout Talent</h1>
      <p class="discover-hero__subtitle">Global directory of discoverable models.</p>
    </div>
    
    <!-- AI Command Bar Trigger -->
    <div class="discover-command-bar">
      <button class="discover-command-bar__trigger" id="ai-search-trigger">
        <span class="discover-command-bar__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 12z"/>
            <path d="M21 12v9"/>
          </svg>
        </span>
        <span class="discover-command-bar__text">Ask Pholio Intelligence to find talent (e.g., 'Edgy look for Berlin streetwear')...</span>
        <span class="discover-command-bar__kbd">⌘K</span>
      </button>
    </div>
    
    <!-- Map View Toggle -->
    <button class="discover-hero__map-toggle" type="button">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      Map View
    </button>
  </div>
</section>

<!-- AI Search Modal -->
<div class="discover-modal" id="ai-search-modal" style="display: none;">
  <div class="discover-modal__overlay" id="modal-overlay"></div>
  <div class="discover-modal__container">
    <div class="discover-modal__content">
      <!-- Header -->
      <div class="discover-modal__header">
        <h2 class="discover-modal__title discover-title">🎯 Ask Pholio Intelligence</h2>
        <button class="discover-modal__close" id="ai-search-close"
 type="button" aria-label="Close">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      
      <!-- Tabs -->
      <div class="discover-modal__tabs">
        <button class="discover-modal__tab discover-modal__tab--active" data-tab="natural" type="button">
          ✨ Natural Language
        </button>
        <button class="discover-modal__tab" data-tab="image" type="button">
          📸 Image Match
        </button>
        <button class="discover-modal__tab" data-tab="voice" type="button">
          🎤 Voice Command
        </button>
      </div>
      
      <!-- Search Input -->
      <div class="discover-modal__search">
        <input 
          type="text" 
          placeholder="Type your search..."
          class="discover-modal__input"
          id="ai-search-input"
          autocomplete="off"
        />
        <button class="discover-modal__submit" type="button">
          Search →
        </button>
      </div>
      
      <!-- AI Thinking Indicator -->
      <div class="discover-modal__thinking" id="ai-thinking" style="display: none;">
        <div class="discover-modal__thinking-animation"></div>
        <p class="discover-modal__thinking-text">
          Analyzing <span id="profile-count">10,247</span> profiles...
        </p>
      </div>
      
      <!-- Suggested Queries -->
      <div class="discover-modal__section">
        <h3 class="discover-modal__section-title">SUGGESTED QUERIES</h3>
        <ul class="discover-modal__suggestions">
          <li class="discover-modal__suggestion-item">
            <button class="discover-modal__suggestion" data-query="Redhead with freckles, height > 175cm" type="button">
              Redhead with freckles, height > 175cm
            </button>
          </li>
          <li class="discover-modal__suggestion-item">
            <button class="discover-modal__suggestion" data-query="Streetwear aesthetic, Berlin based, edgy look" type="button">
              Streetwear aesthetic, Berlin based, edgy look
            </button>
          </li>
          <li class="discover-modal__suggestion-item">
            <button class="discover-modal__suggestion" data-query="Classic beauty for luxury jewelry campaign" type="button">
              Classic beauty for luxury jewelry campaign
            </button>
          </li>
          <li class="discover-modal__suggestion-item">
            <button class="discover-modal__suggestion" data-query="High fashion editorial, unique features" type="button">
              High fashion editorial, unique features
            </button>
          </li>
        </ul>
      </div>
      
      <!-- AI Capabilities -->
      <div class="discover-modal__section">
        <h3 class="discover-modal__section-title">AI CAPABILITIES</h3>
        <div class="discover-modal__chips">
          <span class="discover-chip">Find red hair</span>
          <span class="discover-chip">Runway ready</span>
          <span class="discover-chip">Lives in Paris</span>
          <span class="discover-chip">Available in Peru</span>
          <span class="discover-chip">Streetwear vibe</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- View Controls & Results Count -->
<section class="discover-controls">
  <div class="discover-controls__left">
    <div class="discover-controls__results" id="discover-results-count">
      <!-- Results count will be populated by JavaScript -->
    </div>
    <div class="discover-controls__view-toggle" role="group" aria-label="View mode">
      <button 
        type="button" 
        class="discover-controls__view-btn discover-controls__view-btn--active" 
        data-view="grid"
        aria-label="Grid view"
        title="Grid view"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7"/>
          <rect x="14" y="3" width="7" height="7"/>
          <rect x="14" y="14" width="7" height="7"/>
          <rect x="3" y="14" width="7" height="7"/>
        </svg>
      </button>
      <button 
        type="button" 
        class="discover-controls__view-btn" 
        data-view="list"
        aria-label="List view"
        title="List view"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="8" y1="6" x2="21" y2="6"/>
          <line x1="8" y1="12" x2="21" y2="12"/>
          <line x1="8" y1="18" x2="21" y2="18"/>
          <line x1="3" y1="6" x2="3.01" y2="6"/>
          <line x1="3" y1="12" x2="3.01" y2="12"/>
          <line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="discover-controls__right">
    <div class="discover-controls__sort">
      <label for="discover-sort" class="discover-controls__sort-label">Sort:</label>
      <select id="discover-sort" class="discover-controls__sort-select">
        <option value="relevance">Relevance</option>
        <option value="newest">Newest First</option>
        <option value="az">A-Z</option>
        <option value="height">Height</option>
        <option value="location">Location</option>
      </select>
    </div>
  </div>
</section>
