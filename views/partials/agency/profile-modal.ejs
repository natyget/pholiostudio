<!-- Profile Detail Modal - Editorial Luxury Overlay -->
<div class="profile-modal" id="profile-modal" style="display: none;" aria-hidden="true">
  <div class="profile-modal__overlay" id="profile-modal-overlay"></div>
  
  <div class="profile-modal__container">
    <div class="profile-modal__content">
      <!-- Top Navigation -->
      <div class="profile-modal__nav">
        <button class="profile-modal__back" id="profile-modal-close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Back to Discovery
        </button>
        
        <div class="profile-modal__actions-top">
          <button class="profile-modal__action-btn" title="Share Profile">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
              <polyline points="16 6 12 2 8 6"/>
              <line x1="12" y1="2" x2="12" y2="15"/>
            </svg>
          </button>
          <button class="profile-modal__action-btn" title="Add to Board">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Header Section -->
      <div class="profile-modal__header">
        <div class="profile-modal__title-group">
          <h1 class="profile-modal__name discover-title" id="modal-profile-name">Loading...</h1>
          <div class="profile-modal__badges" id="modal-badges">
            <!-- Populated by JS -->
          </div>
        </div>
        
        <div class="profile-modal__meta discover-mono">
          <span id="modal-location">--</span>
          <span class="profile-modal__meta-divider">•</span>
          <span id="modal-age">-- Years</span>
          <span class="profile-modal__meta-divider">•</span>
          <span id="modal-height">--</span>
        </div>
      </div>

      <!-- Tabs -->
      <div class="profile-modal__tabs">
        <button class="profile-modal__tab profile-modal__tab--active" data-tab="overview">Overview</button>
        <button class="profile-modal__tab" data-tab="insights">AI Insights</button>
        <button class="profile-modal__tab" data-tab="communication">Communication</button>
      </div>

      <!-- Main Content -->
      <div class="profile-modal__body">
        <!-- Left Column: Image -->
        <div class="profile-modal__left">
          <div class="profile-modal__image-container">
            <img id="modal-image" src="" alt="" class="profile-modal__image" />
            <div class="profile-modal__match-badge" id="modal-match-badge" style="display: none;">
              ✨ Match Score: <span id="modal-match-score">--</span>%
            </div>
          </div>
        </div>

        <!-- Right Column: Details -->
        <div class="profile-modal__right">
          <!-- Measurements Section -->
          <section class="profile-modal__section">
            <h3 class="profile-modal__section-title discover-mono">Measurements</h3>
            <div class="profile-modal__measurements">
              <div class="profile-modal__measurement">
                <label>BUST</label>
                <span id="modal-bust">--</span>
              </div>
              <div class="profile-modal__measurement">
                <label>WAIST</label>
                <span id="modal-waist">--</span>
              </div>
              <div class="profile-modal__measurement">
                <label>HIPS</label>
                <span id="modal-hips">--</span>
              </div>
              <div class="profile-modal__measurement">
                <label>SHOES</label>
                <span id="modal-shoes">--</span>
              </div>
              <div class="profile-modal__measurement">
                <label>EYES</label>
                <span id="modal-eyes">--</span>
              </div>
              <div class="profile-modal__measurement">
                <label>HAIR</label>
                <span id="modal-hair">--</span>
              </div>
            </div>
          </section>

          <!-- Categories Section -->
          <section class="profile-modal__section">
            <h3 class="profile-modal__section-title discover-mono">Categories</h3>
            <div class="profile-modal__categories" id="modal-categories">
              <!-- Populated by JS -->
            </div>
          </section>

          <!-- About Section -->
          <section class="profile-modal__section">
            <h3 class="profile-modal__section-title discover-mono">About</h3>
            <p class="profile-modal__bio discover-body" id="modal-bio">
              No bio available.
            </p>
          </section>

          <!-- Action Buttons -->
          <div class="profile-modal__actions">
            <button class="profile-modal__btn profile-modal__btn--secondary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
              View Comp Card
            </button>
            <button class="profile-modal__btn profile-modal__btn--primary" id="modal-invite-btn">
              Invite to Apply
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
