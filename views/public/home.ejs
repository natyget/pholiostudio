<section class="homepage-portfolio-showcase" id="homepage-portfolio-showcase">
  <div class="homepage-portfolio-showcase__container">
    <div class="homepage-portfolio-showcase__header">
      <div class="homepage-portfolio-showcase__header-content">
        <span class="homepage-portfolio-showcase__badge">Portfolio Showcase</span>
        <div class="homepage-portfolio-showcase__headline-wrapper">
          <h2 class="homepage-portfolio-showcase__headline">
            <span class="homepage-portfolio-showcase__headline-fashion">See Pholio</span>
            <span class="homepage-portfolio-showcase__headline-ai">in action.</span>
          </h2>
          <div class="homepage-portfolio-showcase__accent-line"></div>
        </div>
        <p class="homepage-portfolio-showcase__subheadline">Real portfolios from our community showcasing AI-curated bios, organized stats, and editorial-quality presentation.</p>
      </div>
    </div>
    
    <div class="homepage-portfolio-showcase__grid">
      <% featuredTalents.slice(0, 9).forEach((talent, index) => { %>
        <% 
          // Vary aspect ratios: alternate between portrait (3:4) and landscape (4:3)
          // For 9 items in 3x3 grid: indices 1, 4, 7 are landscape (every 3rd starting from 1)
          const isPortrait = index % 3 !== 1; // Most are portrait, every 3rd one (index 1, 4, 7) is landscape
          const aspectClass = isPortrait ? 'homepage-portfolio-showcase__card--portrait' : 'homepage-portfolio-showcase__card--landscape';
          
          // Ensure we have a valid image URL, fallback to placeholder if missing
          const imageUrl = talent.hero_image && talent.hero_image !== '' && talent.hero_image !== '/images/placeholder.jpg' 
            ? talent.hero_image 
            : 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=900&q=80';
        %>
        <a 
          href="<%= talent.slug ? '/portfolio/' + talent.slug : '#' %>" 
          class="homepage-portfolio-showcase__card <%= aspectClass %>" 
          data-index="<%= index %>"
          data-talent-slug="<%= talent.slug || '' %>"
          data-talent-name="<%= talent.first_name %> <%= talent.last_name %>"
          data-talent-city="<%= talent.city || '' %>"
          data-talent-image="<%= imageUrl %>"
        >
          <div class="homepage-portfolio-showcase__image-wrapper">
            <img 
              src="<%= imageUrl %>" 
              alt="<%= talent.first_name %> <%= talent.last_name %>"
              class="homepage-portfolio-showcase__image"
              loading="lazy"
