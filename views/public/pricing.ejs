<!-- Editorial Header: Compact and elegant -->
<section class="pricing-header" id="pricing-header">
  <div class="pricing-header__container">
    <span class="pricing-header__badge">Pricing</span>
    <h1 class="pricing-header__headline">
      <span class="pricing-header__headline-fashion">Professional portfolios.</span>
      <span class="pricing-header__headline-ai">Editorial quality.</span>
    </h1>
    <p class="pricing-header__subheadline">Start free. Upgrade when you're ready.</p>
    <div class="pricing-header__accent"></div>
  </div>
</section>

<!-- Split-Screen Editorial Pricing Layout -->
<section class="pricing-spread" id="pricing-spread">
  <div class="pricing-spread__container">
    <!-- Pricing Toggle -->
    <div class="pricing-toggle">
      <label class="pricing-toggle__label pricing-toggle__label--monthly">Monthly</label>
      <button type="button" class="pricing-toggle__switch" id="pricing-toggle" aria-label="Toggle between monthly and yearly pricing" aria-pressed="false">
        <span class="pricing-toggle__slider"></span>
      </button>
      <label class="pricing-toggle__label pricing-toggle__label--yearly">
        Yearly
        <span class="pricing-toggle__badge">Save 17%</span>
      </label>
    </div>

    <div class="pricing-spread__layout">

      <!-- Left: Pro (Primary Focus - 60%) -->
      <div class="pricing-card pricing-card--pro">
        <div class="pricing-card__badge pricing-card__badge--pro">Pro</div>

        <div class="pricing-card__header">
          <div class="pricing-card__price">
            <span class="pricing-card__currency">$</span>
            <span class="pricing-card__amount" data-monthly="9.99" data-yearly="99.00">9.99</span>
            <span class="pricing-card__period" data-monthly="/month" data-yearly="/year">/month</span>
          </div>
          <p class="pricing-card__tagline">The professional standard for working talent and agencies.</p>
          <p class="pricing-card__billing-note" data-yearly="Billed annually. Equivalent to $8.25/month." style="display: none;"></p>
        </div>

        <div class="pricing-card__preview">
          <div class="pricing-card__preview-image">
            <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?auto=format&fit=crop&w=800&q=80"
              alt="Pro portfolio preview" loading="lazy">
            <div class="pricing-card__preview-overlay">
              <div class="pricing-card__preview-label">Live Portfolio</div>
            </div>
          </div>
        </div>

        <div class="pricing-card__features">
          <div class="pricing-card__feature-item">
            <div class="pricing-card__feature-icon">✓</div>
            <div class="pricing-card__feature-content">
              <div class="pricing-card__feature-title">Custom URL</div>
              <div class="pricing-card__feature-desc">Your own branded link: yourname.zipsite.com</div>
            </div>
          </div>

          <div class="pricing-card__feature-item">
            <div class="pricing-card__feature-icon">✓</div>
            <div class="pricing-card__feature-content">
              <div class="pricing-card__feature-title">Custom Branding</div>
              <div class="pricing-card__feature-desc">Full customization, no watermarks</div>
            </div>
          </div>

          <div class="pricing-card__feature-item">
            <div class="pricing-card__feature-icon">✓</div>
            <div class="pricing-card__feature-content">
              <div class="pricing-card__feature-title">Pro PDF Themes</div>
              <div class="pricing-card__feature-desc">Noir, Studio, Archive, Slate, and more</div>
            </div>
          </div>

          <div class="pricing-card__feature-item">
            <div class="pricing-card__feature-icon">✓</div>
            <div class="pricing-card__feature-content">
              <div class="pricing-card__feature-title">Full Analytics</div>
              <div class="pricing-card__feature-desc">Full analytics suite with advanced tracking</div>
            </div>
          </div>

          <div class="pricing-card__feature-item">
            <div class="pricing-card__feature-icon">✓</div>
            <div class="pricing-card__feature-content">
              <div class="pricing-card__feature-title">Advanced AI Curation</div>
              <div class="pricing-card__feature-desc">Enhanced processing and refinement</div>
            </div>
          </div>

          <div class="pricing-card__feature-item">
            <div class="pricing-card__feature-icon">✓</div>
            <div class="pricing-card__feature-content">
              <div class="pricing-card__feature-title">Video Reels Support</div>
              <div class="pricing-card__feature-desc">Embed video content in your portfolio</div>
            </div>
          </div>
        </div>

        <a href="/pro/upgrade" class="pricing-card__cta pricing-card__cta--pro button button-primary">
          Upgrade to Pro
        </a>

        <p class="pricing-card__note">Cancel anytime. No questions asked.</p>
      </div>

      <!-- Right: Free (Secondary - 40%) -->
      <div class="pricing-card pricing-card--free">
        <div class="pricing-card__badge pricing-card__badge--free">Free</div>

        <div class="pricing-card__header">
          <div class="pricing-card__price">
            <span class="pricing-card__amount pricing-card__amount--free">$0</span>
          </div>
          <p class="pricing-card__tagline pricing-card__tagline--free">Start with the AI-curated PDF comp card.</p>
        </div>

        <div class="pricing-card__preview pricing-card__preview--free">
          <div class="pricing-card__preview-image pricing-card__preview-image--free">
            <div class="pricing-card__preview-placeholder">
              <div class="pricing-card__preview-placeholder-icon">📄</div>
              <div class="pricing-card__preview-placeholder-text">PDF Comp Card</div>
            </div>
            <div class="pricing-card__preview-overlay pricing-card__preview-overlay--free">
              <div class="pricing-card__preview-label pricing-card__preview-label--free">Free PDF</div>
            </div>
          </div>
        </div>

        <div class="pricing-card__features pricing-card__features--free">
          <div class="pricing-card__feature-item pricing-card__feature-item--free">
            <div class="pricing-card__feature-icon">✓</div>
            <div class="pricing-card__feature-content">
              <div class="pricing-card__feature-title">AI-Refined Bio & Stats</div>
            </div>
          </div>

          <div class="pricing-card__feature-item pricing-card__feature-item--free">
            <div class="pricing-card__feature-icon">✓</div>
            <div class="pricing-card__feature-content">
              <div class="pricing-card__feature-title">Printable PDF Comp Card</div>
            </div>
          </div>

          <div class="pricing-card__feature-item pricing-card__feature-item--free">
            <div class="pricing-card__feature-icon">✓</div>
            <div class="pricing-card__feature-content">
              <div class="pricing-card__feature-title">Ink Theme (Free)</div>
            </div>
          </div>

          <div class="pricing-card__feature-item pricing-card__feature-item--free">
            <div class="pricing-card__feature-icon">✓</div>
            <div class="pricing-card__feature-content">
              <div class="pricing-card__feature-title">Default Branding</div>
              <div class="pricing-card__feature-desc">Watermark, ZipSite colors, non-customizable</div>
            </div>
          </div>
        </div>

        <a href="/apply" class="pricing-card__cta pricing-card__cta--free button button-secondary">
          Start Free PDF
        </a>

        <p class="pricing-card__note pricing-card__note--free">Perfect for trying ZipSite</p>
      </div>
    </div>
  </div>
</section>

<!-- Visual Comparison Section -->
<section class="pricing-comparison" id="pricing-comparison">
  <div class="pricing-comparison__container">
    <div class="pricing-comparison__header">
      <h2 class="pricing-comparison__title">What's the difference?</h2>
      <p class="pricing-comparison__subtitle">Both tiers include AI curation. Pro unlocks the full professional
        experience.</p>
    </div>

    <div class="pricing-comparison__grid">
      <div class="comparison-item">
        <div class="comparison-item__icon">🎨</div>
        <div class="comparison-item__title">PDF Themes</div>
        <div class="comparison-item__free">Ink (Free)</div>
        <div class="comparison-item__pro">Ink, Noir, Studio, Archive, Slate</div>
      </div>

      <div class="comparison-item">
        <div class="comparison-item__icon">🌐</div>
        <div class="comparison-item__title">Portfolio URL</div>
        <div class="comparison-item__free">Default URL<br><small>zipsite.com/portfolio/yourname</small></div>
        <div class="comparison-item__pro">Custom URL<br><small>yourname.zipsite.com</small></div>
      </div>

      <div class="comparison-item">
        <div class="comparison-item__icon">✨</div>
        <div class="comparison-item__title">Branding</div>
        <div class="comparison-item__free">Default Branding<br><small>Watermark, ZipSite colors, non-customizable</small></div>
        <div class="comparison-item__pro">Custom Branding<br><small>Full customization</small></div>
      </div>

      <div class="comparison-item">
        <div class="comparison-item__icon">📊</div>
        <div class="comparison-item__title">Analytics</div>
        <div class="comparison-item__free">Basic Analytics<br><small>Basic dashboard, limited data</small></div>
        <div class="comparison-item__pro">Full Analytics<br><small>Full analytics suite</small></div>
      </div>

      <div class="comparison-item">
        <div class="comparison-item__icon">🎬</div>
        <div class="comparison-item__title">Video Support</div>
        <div class="comparison-item__free">—</div>
        <div class="comparison-item__pro">Reels & lookbooks</div>
      </div>

      <div class="comparison-item">
        <div class="comparison-item__icon">⚡</div>
        <div class="comparison-item__title">AI Processing</div>
        <div class="comparison-item__free">Standard</div>
        <div class="comparison-item__pro">Advanced</div>
      </div>
    </div>
  </div>
</section>

<script src="/scripts/pricing.js?v=<%= Date.now() %>-<%= Math.random().toString(36).substring(7) %>" defer></script>