<%- include('../partials/header-universal') %>

<style>
  :root {
    --cream-bg: #faf9f7;
    --serif-font: 'Noto Serif Display', 'Times New Roman', serif;
    --sans-font: 'Inter', 'Helvetica Neue', Arial, sans-serif;
  }
  
  body {
    background: var(--cream-bg);
    font-family: var(--sans-font);
    margin: 0;
    padding: 0;
    min-height: 100vh;
  }
  
  .onboarding-container {
    max-width: 700px;
    width: 100%;
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  
  .onboarding-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .onboarding-title {
    font-family: var(--serif-font);
    font-size: 2.25rem;
    font-weight: 400;
    color: #0f172a;
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.02em;
  }
  
  .onboarding-subtitle {
    font-family: var(--sans-font);
    font-size: 1rem;
    color: #475569;
    margin: 0;
  }
  
  .step-indicator {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }
  
  .step-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(15, 23, 42, 0.2);
    transition: all 0.3s ease;
  }
  
  .step-dot.active {
    background: var(--color-accent);
    width: 24px;
    border-radius: 4px;
  }
  
  .onboarding-form {
    background: #ffffff;
    border-radius: 18px;
    padding: 2.5rem;
    box-shadow: 0 2px 8px rgba(15, 23, 42, 0.08);
  }
  
  .form-section {
    margin-bottom: 2.5rem;
  }
  
  .form-section-title {
    font-family: var(--serif-font);
    font-size: 1.5rem;
    font-weight: 400;
    color: #0f172a;
    margin: 0 0 1rem 0;
    letter-spacing: -0.01em;
  }
  
  .form-section-description {
    font-family: var(--sans-font);
    font-size: 0.875rem;
    color: #64748b;
    margin: 0 0 1.5rem 0;
  }
  
  .tag-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  
  .tag-option {
    padding: 0.625rem 1.25rem;
    font-family: var(--sans-font);
    font-size: 0.875rem;
    font-weight: 500;
    color: #475569;
    background: #faf9f7;
    border: 2px solid rgba(15, 23, 42, 0.1);
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .tag-option:hover {
    border-color: var(--color-accent);
    background: #fefbf5;
  }
  
  .tag-option.selected {
    background: var(--color-accent);
    color: #ffffff;
    border-color: var(--color-accent);
  }
  
  .markets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.75rem;
  }
  
  .market-option {
    padding: 0.75rem 1rem;
    font-family: var(--sans-font);
    font-size: 0.875rem;
    font-weight: 500;
    color: #475569;
    background: #faf9f7;
    border: 2px solid rgba(15, 23, 42, 0.1);
    border-radius: 8px;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s ease;
  }
  
  .market-option:hover {
    border-color: var(--color-accent);
    background: #fefbf5;
  }
  
  .market-option.selected {
    background: var(--color-accent);
    color: #ffffff;
    border-color: var(--color-accent);
  }
  
  .form-actions {
    display: flex;
    justify-content: space-between;
    margin-top: 2.5rem;
    gap: 1rem;
  }
  
  .btn {
    padding: 0.875rem 2rem;
    font-family: var(--sans-font);
    font-size: 1rem;
    font-weight: 500;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .btn-primary {
    background: #0f172a;
    color: #ffffff;
  }
  
  .btn-primary:hover:not(:disabled) {
    background: #1e293b;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
  }
  
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  
  .btn-secondary {
    background: transparent;
    color: #475569;
    border: 1px solid rgba(15, 23, 42, 0.15);
  }
  
  .btn-secondary:hover {
    background: rgba(15, 23, 42, 0.05);
  }
</style>

<div class="onboarding-container">
  <div class="onboarding-header">
    <h1 class="onboarding-title">Your Preferences</h1>
    <p class="onboarding-subtitle">Help us understand what you're scouting for</p>
    
    <div class="step-indicator">
      <div class="step-dot active"></div>
      <div class="step-dot active"></div>
      <div class="step-dot active"></div>
      <div class="step-dot"></div>
    </div>
  </div>
  
  <form id="agency-step3-form" class="onboarding-form">
    <div class="form-section">
      <h2 class="form-section-title">What are you scouting for?</h2>
      <p class="form-section-description">Select all that apply. This helps our AI match you with relevant talent.</p>
      
      <div class="tag-grid">
        <div class="tag-option" data-tag="Editorial">Editorial</div>
        <div class="tag-option" data-tag="Commercial">Commercial</div>
        <div class="tag-option" data-tag="Runway">Runway</div>
        <div class="tag-option" data-tag="New Faces">New Faces</div>
        <div class="tag-option" data-tag="Influencers">Influencers</div>
        <div class="tag-option" data-tag="Actors">Actors</div>
        <div class="tag-option" data-tag="Athletes">Athletes</div>
        <div class="tag-option" data-tag="Artists">Artists</div>
      </div>
    </div>
    
    <div class="form-section">
      <h2 class="form-section-title">Select regions you scout in</h2>
      <p class="form-section-description">Choose the markets where you actively scout talent.</p>
      
      <div class="markets-grid">
        <div class="market-option" data-market="New York">New York</div>
        <div class="market-option" data-market="Los Angeles">Los Angeles</div>
        <div class="market-option" data-market="London">London</div>
        <div class="market-option" data-market="Paris">Paris</div>
        <div class="market-option" data-market="Milan">Milan</div>
        <div class="market-option" data-market="Tokyo">Tokyo</div>
        <div class="market-option" data-market="Sydney">Sydney</div>
        <div class="market-option" data-market="Toronto">Toronto</div>
        <div class="market-option" data-market="Miami">Miami</div>
        <div class="market-option" data-market="Chicago">Chicago</div>
        <div class="market-option" data-market="Berlin">Berlin</div>
        <div class="market-option" data-market="Barcelona">Barcelona</div>
      </div>
    </div>
    
    <div class="form-actions">
      <button type="button" class="btn btn-secondary" onclick="window.location.href='/onboarding/agency/step2'">Back</button>
      <button type="submit" class="btn btn-primary" id="submit-btn">Continue</button>
    </div>
  </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('agency-step3-form');
  const tagOptions = document.querySelectorAll('.tag-option');
  const marketOptions = document.querySelectorAll('.market-option');
  const submitBtn = document.getElementById('submit-btn');
  
  const selectedTags = new Set();
  const selectedMarkets = new Set();
  
  // Handle tag selection
  tagOptions.forEach(option => {
    option.addEventListener('click', function() {
      const tag = this.dataset.tag;
      if (selectedTags.has(tag)) {
        selectedTags.delete(tag);
        this.classList.remove('selected');
      } else {
        selectedTags.add(tag);
        this.classList.add('selected');
      }
    });
  });
  
  // Handle market selection
  marketOptions.forEach(option => {
    option.addEventListener('click', function() {
      const market = this.dataset.market;
      if (selectedMarkets.has(market)) {
        selectedMarkets.delete(market);
        this.classList.remove('selected');
      } else {
        selectedMarkets.add(market);
        this.classList.add('selected');
      }
    });
  });
  
  // Form submission
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving...';
    
    try {
      const response = await fetch('/onboarding/agency/step3', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          tags: Array.from(selectedTags),
          markets: Array.from(selectedMarkets)
        })
      });
      
      const data = await response.json();
      
      if (data.success) {
        window.location.href = data.redirect;
      } else {
        alert(data.errors?.general?.[0] || 'An error occurred. Please try again.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Continue';
      }
    } catch (error) {
      console.error('Error submitting form:', error);
      alert('An error occurred. Please try again.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Continue';
    }
  });
});
</script>

<%- include('../partials/footer-universal') %>

