<%- include('../partials/header-universal') %>

<style>
  :root {
    --cream-bg: #faf9f7;
    --serif-font: 'Noto Serif Display', 'Times New Roman', serif;
    --sans-font: 'Inter', 'Helvetica Neue', Arial, sans-serif;
  }
  
  body {
    background: var(--cream-bg);
    font-family: var(--sans-font);
    margin: 0;
    padding: 0;
    min-height: 100vh;
  }
  
  .onboarding-container {
    max-width: 700px;
    width: 100%;
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  
  .onboarding-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .onboarding-title {
    font-family: var(--serif-font);
    font-size: 2.25rem;
    font-weight: 400;
    color: #0f172a;
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.02em;
  }
  
  .onboarding-subtitle {
    font-family: var(--sans-font);
    font-size: 1rem;
    color: #475569;
    margin: 0;
  }
  
  .step-indicator {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }
  
  .step-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(15, 23, 42, 0.2);
    transition: all 0.3s ease;
  }
  
  .step-dot.active {
    background: var(--color-accent);
    width: 24px;
    border-radius: 4px;
  }
  
  .onboarding-form {
    background: #ffffff;
    border-radius: 18px;
    padding: 2.5rem;
    box-shadow: 0 2px 8px rgba(15, 23, 42, 0.08);
  }
  
  .form-section {
    margin-bottom: 2rem;
  }
  
  .form-section-title {
    font-family: var(--serif-font);
    font-size: 1.5rem;
    font-weight: 400;
    color: #0f172a;
    margin: 0 0 1rem 0;
    letter-spacing: -0.01em;
  }
  
  .form-section-description {
    font-family: var(--sans-font);
    font-size: 0.875rem;
    color: #64748b;
    margin: 0 0 1.5rem 0;
  }
  
  .email-input-group {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  
  .form-input {
    flex: 1;
    padding: 0.875rem 1rem;
    font-family: var(--sans-font);
    font-size: 1rem;
    color: #0f172a;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.15);
    border-radius: 8px;
    transition: all 0.2s ease;
  }
  
  .form-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(201, 165, 90, 0.1);
  }
  
  .btn-add {
    padding: 0.875rem 1.5rem;
    font-family: var(--sans-font);
    font-size: 0.875rem;
    font-weight: 500;
    color: #0f172a;
    background: #faf9f7;
    border: 1px solid rgba(15, 23, 42, 0.15);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .btn-add:hover {
    background: #f1f0ed;
    border-color: var(--color-accent);
  }
  
  .email-list {
    margin-top: 1rem;
  }
  
  .email-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: #faf9f7;
    border-radius: 8px;
    margin-bottom: 0.5rem;
  }
  
  .email-item-text {
    font-family: var(--sans-font);
    font-size: 0.875rem;
    color: #0f172a;
  }
  
  .btn-remove {
    padding: 0.25rem 0.75rem;
    font-family: var(--sans-font);
    font-size: 0.75rem;
    color: #dc2626;
    background: transparent;
    border: 1px solid #dc2626;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .btn-remove:hover {
    background: #dc2626;
    color: #ffffff;
  }
  
  .skip-note {
    font-family: var(--sans-font);
    font-size: 0.875rem;
    color: #64748b;
    margin-top: 1rem;
    font-style: italic;
  }
  
  .form-actions {
    display: flex;
    justify-content: space-between;
    margin-top: 2.5rem;
    gap: 1rem;
  }
  
  .btn {
    padding: 0.875rem 2rem;
    font-family: var(--sans-font);
    font-size: 1rem;
    font-weight: 500;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .btn-primary {
    background: #0f172a;
    color: #ffffff;
  }
  
  .btn-primary:hover:not(:disabled) {
    background: #1e293b;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
  }
  
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  
  .btn-secondary {
    background: transparent;
    color: #475569;
    border: 1px solid rgba(15, 23, 42, 0.15);
  }
  
  .btn-secondary:hover {
    background: rgba(15, 23, 42, 0.05);
  }
</style>

<div class="onboarding-container">
  <div class="onboarding-header">
    <h1 class="onboarding-title">Invite Your Team</h1>
    <p class="onboarding-subtitle">Add colleagues to your agency dashboard</p>
    
    <div class="step-indicator">
      <div class="step-dot active"></div>
      <div class="step-dot active"></div>
      <div class="step-dot active"></div>
      <div class="step-dot active"></div>
    </div>
  </div>
  
  <form id="agency-step4-form" class="onboarding-form">
    <div class="form-section">
      <h2 class="form-section-title">Team Members</h2>
      <p class="form-section-description">Invite agents and scouts to collaborate on your roster. You can add more later.</p>
      
      <div class="email-input-group">
        <input 
          type="email" 
          id="team-email-input" 
          class="form-input" 
          placeholder="colleague@agency.com"
        >
        <button type="button" class="btn-add" id="add-email-btn">Add</button>
      </div>
      
      <div class="email-list" id="email-list"></div>
      
      <p class="skip-note">You can skip this step and invite team members later from your dashboard.</p>
    </div>
    
    <div class="form-actions">
      <button type="button" class="btn btn-secondary" onclick="window.location.href='/onboarding/agency/step3'">Back</button>
      <button type="submit" class="btn btn-primary" id="submit-btn">Complete Setup</button>
    </div>
  </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('agency-step4-form');
  const emailInput = document.getElementById('team-email-input');
  const addEmailBtn = document.getElementById('add-email-btn');
  const emailList = document.getElementById('email-list');
  const submitBtn = document.getElementById('submit-btn');
  
  const teamEmails = [];
  
  // Add email to list
  function addEmail(email) {
    const trimmedEmail = email.trim().toLowerCase();
    if (!trimmedEmail || !trimmedEmail.includes('@')) {
      alert('Please enter a valid email address');
      return;
    }
    
    if (teamEmails.includes(trimmedEmail)) {
      alert('This email is already in the list');
      return;
    }
    
    teamEmails.push(trimmedEmail);
    renderEmailList();
    emailInput.value = '';
  }
  
  // Remove email from list
  function removeEmail(email) {
    const index = teamEmails.indexOf(email);
    if (index > -1) {
      teamEmails.splice(index, 1);
      renderEmailList();
    }
  }
  
  // Render email list
  function renderEmailList() {
    if (teamEmails.length === 0) {
      emailList.innerHTML = '';
      return;
    }
    
    emailList.innerHTML = teamEmails.map(email => `
      <div class="email-item">
        <span class="email-item-text">${email}</span>
        <button type="button" class="btn-remove" onclick="removeEmail('${email}')">Remove</button>
      </div>
    `).join('');
  }
  
  // Make removeEmail available globally for onclick
  window.removeEmail = removeEmail;
  
  // Add email button
  addEmailBtn.addEventListener('click', function() {
    if (emailInput.value) {
      addEmail(emailInput.value);
    }
  });
  
  // Add email on Enter
  emailInput.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
      e.preventDefault();
      if (emailInput.value) {
        addEmail(emailInput.value);
      }
    }
  });
  
  // Form submission
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'Completing...';
    
    try {
      const response = await fetch('/onboarding/agency/step4', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          team_emails: teamEmails
        })
      });
      
      const data = await response.json();
      
      if (data.success) {
        // Show success message if provided
        if (data.message) {
          alert(data.message);
        }
        window.location.href = data.redirect;
      } else {
        alert(data.errors?.general?.[0] || 'An error occurred. Please try again.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Complete Setup';
      }
    } catch (error) {
      console.error('Error submitting form:', error);
      alert('An error occurred. Please try again.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Complete Setup';
    }
  });
});
</script>

<%- include('../partials/footer-universal') %>

