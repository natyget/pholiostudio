<!-- Editorial Header: Matching features/pricing style -->
<section class="partners-listing-header" id="partners-listing-header">
  <div class="partners-listing-header__container">
    <span class="partners-listing-header__badge">Partners & Agencies</span>
    <h1 class="partners-listing-header__headline">
      <span class="partners-listing-header__headline-fashion">Connect with top agencies.</span>
      <span class="partners-listing-header__headline-ai">Worldwide network.</span>
    </h1>
    <p class="partners-listing-header__subheadline">Apply directly to partner agencies or browse their casting boards. All agencies on Pholio are verified and actively scouting talent.</p>
    <div class="partners-listing-header__accent"></div>
  </div>
</section>

<!-- Confirmed Partners Section -->
<% if (agencies && agencies.length > 0) { %>
  <section class="partners-listing-section" id="partners-listing-confirmed">
    <div class="partners-listing-section__container">
      <div class="partners-listing-section__header">
        <h2 class="partners-listing-section__title">Confirmed Partners</h2>
        <p class="partners-listing-section__subtitle">Verified agencies actively using Pholio to discover talent</p>
      </div>
      
      <div class="partners-listing-grid">
        <% agencies.forEach(agency => { %>
          <article class="partners-listing-card">
            <div class="partners-listing-card__header">
              <% if (agency.agency_logo_path) { %>
                <img src="<%= agency.agency_logo_path %>" alt="<%= agency.agency_name %> Logo" class="partners-listing-card__logo">
              <% } else { %>
                <div class="partners-listing-card__logo-placeholder">
                  <%= agency.agency_name ? agency.agency_name.charAt(0).toUpperCase() : 'A' %>
                </div>
              <% } %>
              <div class="partners-listing-card__info">
                <h3 class="partners-listing-card__name"><%= agency.agency_name || 'Agency' %></h3>
                <p class="partners-listing-card__location">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                  <%= agency.agency_location || 'Global' %>
                </p>
              </div>
            </div>
            
            <div class="partners-listing-card__body">
              <% if (agency.agency_description) { %>
                <p class="partners-listing-card__description"><%= agency.agency_description %></p>
              <% } %>
              
              <% if (agency.boards && agency.boards.length > 0) { %>
                <div class="partners-listing-card__tags">
                  <% agency.boards.forEach(board => { %>
                    <span class="partners-listing-tag partners-listing-tag--board"><%= board %></span>
                  <% }) %>
                </div>
              <% } %>

              <% if (agency.tags && agency.tags.length > 0) { %>
                <div class="partners-listing-card__tags">
                  <% agency.tags.forEach(tag => { %>
                    <span class="partners-listing-tag partners-listing-tag--status"><%= tag %></span>
                  <% }) %>
                </div>
              <% } %>
            </div>

            <div class="partners-listing-card__footer">
              <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.is_pro) { %>
                <button class="button button-secondary button-sm" disabled>View Boards (Coming Soon)</button>
              <% } else { %>
                <a href="/pro" class="button button-secondary button-sm">View Boards (Studio+)</a>
              <% } %>
              <a href="/apply/agency?agencyId=<%= agency.id %>" class="button button-primary button-sm">Apply with Pholio</a>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
<% } else { %>
  <section class="partners-listing-section partners-listing-section--empty" id="partners-listing-confirmed">
    <div class="partners-listing-section__container">
      <div class="partners-listing-empty">
        <div class="partners-listing-empty__icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <h3 class="partners-listing-empty__title">No confirmed partners yet</h3>
        <p class="partners-listing-empty__description">Check back soon as we continue to onboard top agencies worldwide.</p>
      </div>
    </div>
  </section>
<% } %>

<!-- Coming Soon Section -->
<section class="partners-listing-section partners-listing-section--coming-soon" id="partners-listing-coming-soon">
  <div class="partners-listing-section__container">
    <div class="partners-listing-section__header">
      <h2 class="partners-listing-section__title">Coming Soon</h2>
      <p class="partners-listing-section__subtitle">Onboarding to Pholio soon – create your profile now to be ready.</p>
    </div>
    
    <div class="partners-listing-grid">
      <% comingSoonAgencies.forEach(agency => { %>
        <article class="partners-listing-card partners-listing-card--coming-soon">
          <div class="partners-listing-card__header">
            <div class="partners-listing-card__logo-placeholder partners-listing-card__logo-placeholder--muted">
              <%= agency.name.charAt(0) %>
            </div>
            <div class="partners-listing-card__info">
              <h3 class="partners-listing-card__name"><%= agency.name %></h3>
              <p class="partners-listing-card__location">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
                <%= agency.location %>
              </p>
            </div>
          </div>
          <div class="partners-listing-card__body">
            <p class="partners-listing-card__description"><%= agency.description %></p>
          </div>
          <div class="partners-listing-card__footer">
            <span class="partners-listing-badge partners-listing-badge--coming-soon">Coming Soon</span>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>
