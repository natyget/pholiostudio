{
  "name": "Pholio",
  "version": "1.0.0",
  "description": "Pholio.studio yo",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon server.js",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "dev:all": "concurrently \"npm run dev\" \"npm run client:dev\"",
    "migrate": "knex migrate:latest",
    "migrate:status": "knex migrate:status",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "test": "jest",
    "test:db": "node scripts/test-neon-connection.js",
    "build": "echo 'Build complete'",
    "build:migrate": "npm run migrate && npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@sparticuz/chromium": "^131.0.0",
    "bcrypt": "5.1.1",
    "connect-session-knex": "3.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "ejs": "3.1.10",
    "express": "^4.21.0",
    "express-async-handler": "^1.2.0",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.7.0",
    "groq-sdk": "^0.37.0",
    "gsap": "^3.14.2",
    "helmet": "^8.1.0",
    "knex": "^3.1.0",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.19.0",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.4",
    "serverless-http": "^3.2.0",
    "sharp": "^0.34.5",
    "stripe": "^20.4.0",
    "three": "^0.183.2",
    "uuid": "^9.0.1",
    "validator": "^13.15.26",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "sqlite3": "5.1.7"
  },
  "devDependencies": {
    "axios": "^1.13.5",
    "axios-cookiejar-support": "^6.0.5",
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "tough-cookie": "^6.0.0"
  }
}
